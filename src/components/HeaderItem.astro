---
// HeaderItem.astro
const { dropdown } = Astro.props;
type Item = {
  name: string;
  url: string;
};
---

<div class="relative group py-4">
  <button class="flex items-center gap-1 hover:text-brand-green transition-colors cursor-pointer text-brand-blue font-medium text-md lg:text-xl">
    {dropdown.title}
    <svg class="h-4 w-4 text-gray-400 transition-transform duration-200 group-hover:rotate-180 group-hover:text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  
  <div class="absolute top-full left-0 mt-0 hidden group-hover:flex flex-col min-w-56 rounded-xl bg-white p-2 shadow-xl border border-gray-100/50 animate-in fade-in slide-in-from-top-2 duration-150 z-50">
    {dropdown.subItems.map((item: Item) => (
      <a href={item.url} class="block rounded-lg px-4 py-2.5 text-base text-brand-blue hover:bg-[#FAF8F5] hover:text-brand-green transition-colors font-medium">
        {item.name}
      </a>
    ))}
  </div>
</div>