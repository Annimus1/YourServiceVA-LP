---
interface GridItem {
  title: string;
  description?: string; // <-- ¡Añadida la descripción opcional para la tarjeta!
  iconHtml?: string; 
  iconClass?: string; 
}
interface Props {
  title: string;
  description?: string; // Descripción del encabezado principal
  items: GridItem[];
}
const { title, description, items } = Astro.props;
---

<section class="w-full bg-[#FAF8F5] py-16 px-6 md:py-24 md:px-12 text-[#3d1d0e]">
  <div class="max-w-7xl mx-auto flex flex-col gap-12 md:gap-16">
    
    <header class="text-center flex flex-col gap-4 max-w-3xl mx-auto">
      <h2 class="text-4xl md:text-6xl font-black tracking-tight leading-tight whitespace-pre-line">
        {title}
      </h2>
      {description && (
        <p class="text-gray-600 text-sm md:text-2xl font-semibold leading-relaxed max-w-2xl mx-auto">
          {description}
        </p>
      )}
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((item: GridItem) => (
        <div class="bg-white rounded-xl p-8 border border-gray-100/70 shadow-2xs flex flex-col items-center text-center gap-4 hover:shadow-xs transition-shadow duration-200">
          <div class="text-brand-green shrink-0 w-8 h-8 md:w-12 md:h-12 flex items-center justify-center mb-1">
            {item.iconHtml ? (
              <Fragment set:html={item.iconHtml} />
            ) : item.iconClass ? (
              <i class={`${item.iconClass} text-2xl md:text-4xl`}></i>
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 md:w-12 md:h-12"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
            )}
          </div>

          <h3 class="text-lg md:text-2xl font-bold leading-snug tracking-tight text-[#3d1d0e]">
            {item.title}
          </h3>

          {item.description && (
            <p class="text-gray-500 text-xs md:text-lg font-medium leading-relaxed">
              {item.description}
            </p>
          )}
          
        </div>
      ))}
    </div>

  </div>
</section>