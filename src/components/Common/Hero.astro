---
interface heroDataType {
  titleA: string;
  titleB: string;
  items: string[];
  btn?: {
    text: string;
    link: string;
  };
  photo: string;
  gift?: string;
}

const heroData: heroDataType = Astro.props.heroData || {
  titleA: "Hire Top Virtual",
  titleB: "Assistants",
  items : [],
  photo: ""
}
---

<section class="relative w-full bg-[#FAF8F5] overflow-hidden px-6 py-12 md:py-20 lg:py-28">
  <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    
    {/* COLUMNA IZQUIERDA: Añadida clase 'animate-fade-up' */}
    <div class="lg:col-span-7 flex flex-col gap-6 md:gap-8 order-2 lg:order-1 text-left animate-fade-up">
      
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-[#3d1d0e] tracking-tight leading-tight">
        {heroData.titleA} <br class="hidden sm:inline"/> {heroData.titleB}
      </h1>

      {/* Cada bloque tiene un delay progresivo configurado abajo en el <style> */}
      <ul class="flex flex-col gap-4 text-base sm:text-lg font-medium text-gray-700 delay-1">
        {heroData.items.map(item => (
         <li class="flex items-start gap-3">
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-green text-white text-xs font-bold mt-0.5">
            ✓
          </span>
          <span>{item}</span>
        </li>
        ))}
      </ul>

      {heroData.gift && (
        <div class="inline-flex items-center delay-2">
          <span class="text-lg md:text-xl font-bold text-brand-blue bg-brand-blue/5 px-4 py-2 rounded-lg border border-brand-blue/10">
            🎁 Get $100 Off Your First Month
          </span>
        </div>
      )}

      <div class="flex flex-col sm:flex-row items-center gap-4 mt-2 delay-2">
        <a href={heroData.btn?.link || "#contact"} class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-brand-blue px-8 py-4 text-base font-bold text-white shadow-lg hover:bg-brand-green/90 transition-all transform active:scale-98 cursor-pointer">
          {heroData.btn?.text || "Get Your Virtual Assistant"}
        </a>
        <a href="/pricing" class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-white border-2 border-gray-200 px-8 py-4 text-base font-bold text-brand-blue hover:bg-gray-50 hover:border-gray-300 transition-colors cursor-pointer">
          Pricing
        </a>
      </div>

      <div class="flex flex-wrap items-center gap-6 pt-6 border-t border-gray-200/60 mt-4 delay-3">
        <div class="flex -space-x-3 overflow-hidden">
          <img class="inline-block h-10 w-10 rounded-full ring-2 ring-[#FAF8F5] object-cover" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&q=80&w=100" alt="User 1" />
          <img class="inline-block h-10 w-10 rounded-full ring-2 ring-[#FAF8F5] object-cover" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=100" alt="User 2" />
          <img class="inline-block h-10 w-10 rounded-full ring-2 ring-[#FAF8F5] object-cover" src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&q=80&w=100" alt="User 3" />
        </div>
        
        <div class="flex flex-col gap-0.5">
          <div class="flex items-center gap-1 text-amber-500 text-lg">
            ★ ★ ★ ★ ★
          </div>
          <p class="text-xs font-bold text-gray-500">4.9 (454 reviews)</p>
        </div>

        <div class="hidden sm:block h-8 w-px bg-gray-200"></div>

        <div class="flex items-center gap-4 text-gray-400 font-bold tracking-tight text-sm">
          <span class="text-gray-500">REVIEWED ON</span>
          <span class="text-emerald-600 flex items-center gap-1 font-extrabold text-base">
            <span class="text-xl">★</span> Trustpilot
          </span>
          <span class="text-slate-800 font-black text-base tracking-tighter">Clutch</span>
        </div>
      </div>

    </div>

    {/* COLUMNA DERECHA: Añadida clase 'animate-fade-in-right' para la imagen */}
    <div class="lg:col-span-5 order-1 lg:order-2 flex items-center justify-center relative w-full min-h-85 sm:min-h-110 md:min-h-125 animate-fade-in-right">
      <div class="relative w-full h-full max-w-md lg:max-w-none flex items-center justify-center">
        <img 
          src={heroData.photo || "https://images.unsplash.com/photo-1522202176988-66273c2fd55?auto=format&fit=crop&q=80&w=400"} 
          alt="Hero Image" 
          class="w-4/5 sm:w-auto h-80 sm:h-105 md:h-120 lg:h-130 object-cover lg:object-contain object-center z-10 filter drop-shadow-xl"
        />
        <slot />
      </div>
    </div>

  </div>
</section>

<style>
  /* --- DECLARACIÓN DE LAS ANIMACIONES NATIVAS --- */
  
  /* Entrada suave desde abajo para el contenido */
  .animate-fade-up {
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Entrada lateral limpia para la foto del Hero */
  .animate-fade-in-right {
    animation: fadeInRight 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.2s; /* La foto entra un pelín después */
  }

  /* Tiempos de retraso (Delays) secuenciales para los hijos */
  .delay-1 { animation-delay: 0.15s; }
  .delay-2 { animation-delay: 0.3s; }
  .delay-3 { animation-delay: 0.45s; }

  /* Aseguramos que los elementos con retraso no parpadeen al cargar */
  .animate-fade-up > * {
    animation: inherit;
    animation-name: fadeUp;
    animation-fill-mode: both;
  }

  @keyframes fadeUp {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInRight {
    0% {
      opacity: 0;
      transform: translateX(30px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Mantenemos tu animación previa */
  .animate-bounce-slow {
    animation: softBounce 4s infinite ease-in-out;
  }
  @keyframes softBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
</style>