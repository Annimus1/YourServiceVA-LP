---
const reviews = [
  {
    rating: "5.0",
    text: 'You guys provide an awesome service that I had no idea was possible through Upwork!',
    author: "Isham Hipsher",
    company: "Unwind Land CO"
  },
  {
    rating: "5.0",
    text: "Great news team, the new hires both showed up today and impressed our team manager!",
    author: "Joel",
    company: "Head Hunter"
  },
  {
    rating: "5.0",
    text: "Just want to say thanks so much for putting me in contact with Sean. I was officially hired by him after the 14 days trial!",
    author: "Melvin Almendarez",
    company: "Virtual Assistant"
  },
  {
    rating: "5.0",
    text: `We’ve had an excellent experience working with your team. From the beginning, the process was smooth, professional, and efficient. The staff we’ve hired have been dependable, hardworking, and have integrated seamlessly into our operations.`,
    author: "Liam Pilo",
    company: "Prestige Perfume"
  },
];
---

<section class="w-full bg-[#FAF8F5] py-20 md:py-28 px-0 md:px-6 overflow-hidden border-b border-gray-100">
  <div class="mx-auto max-w-7xl">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 px-6 md:px-0">
      <div class="flex flex-col gap-2">
        <h2 class="text-3xl md:text-5xl font-extrabold text-[#3d1d0e] tracking-tight">
          Client <span class="text-brand-green">Reviews</span>
        </h2>
        <div class="flex flex-wrap items-center gap-3 mt-2">
          <span class="font-bold text-[#3d1d0e] text-base md:text-2xl">Your Service Reviews</span>
          <span class="font-extrabold text-brand-green text-2xl">4.8</span>
          <div class="flex text-amber-500 text-xl">★★★★★</div>
          <span class="text-gray-500 text-sm font-medium">189 reviews</span>
        </div>
      </div>
    </div>

    <div class="relative w-full md:px-12 group/slider">
      
      <button 
        id="clutch-prev-btn" 
        class="absolute left-2 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-white border border-gray-200 hidden md:flex items-center justify-center text-gray-700 shadow-md hover:bg-[#0066cc] hover:text-white transition-all duration-300 select-none cursor-pointer"
        aria-label="Previous page"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>

      <div 
        id="clutch-slider" 
        class="flex flex-row overflow-x-auto flex-nowrap gap-6 pb-6 px-[6vw] md:px-0 snap-x snap-mandatory md:snap-none scroll-smooth scrollbar-none [&::-webkit-scrollbar]:hidden"
      >
        {reviews.map((review, index) => (
          <div 
            class="clutch-card w-[82vw] sm:w-85 lg:w-90 shrink-0 bg-white rounded-2xl p-6 md:p-8 border border-gray-100 shadow-sm flex flex-col justify-between gap-6 snap-center md:snap-start hover:shadow-md transition-all duration-300"
            data-index={index}
          >
            <div class="flex flex-col gap-4">
              <div class="flex items-center gap-2">
                <span class="font-extrabold text-brand-green md:text-xl">{review.rating}</span>
                <div class="flex text-amber-500 text-sm md:text-xl">★★★★★</div>
              </div>
              <p class="text-gray-600 font-medium text-base leading-relaxed md:text-xl">
                "{review.text}"
              </p>
            </div>
            
            <div class="border-t border-gray-100 pt-4 flex flex-col">
              <span class="font-bold text-[#3d1d0e] text-sm md:text-xl">{review.author}</span>
              <span class="text-gray-400 text-xs font-semibold md:text-md">{review.company}</span>
              <div class="flex items-center gap-1.5 text-brand-green text-xs md:text-md font-bold mt-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                  <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-7.446-2.15a.75.75 0 00-1.064-1.054L6.16 11.18l-.947-.948a.75.75 0 10-1.06 1.06l1.477 1.477a.75.75 0 001.06 0l2.266-2.265z" clip-rule="evenodd" />
                </svg>
                Verified Review
              </div>
            </div>
          </div>
        ))}
      </div>

      <button 
        id="clutch-next-btn" 
        class="absolute right-2 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-white border border-gray-200 hidden md:flex items-center justify-center text-gray-700 shadow-md hover:bg-[#0066cc] hover:text-white transition-all duration-300 select-none cursor-pointer"
        aria-label="Next page"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>

      <div id="clutch-dots" class="flex justify-center items-center gap-2 mt-6"></div>

    </div>

  </div>
</section>

<script>
  function initClutchSlider() {
    const slider = document.getElementById('clutch-slider');
    const prevBtn = document.getElementById('clutch-prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('clutch-next-btn') as HTMLButtonElement;
    const dotsContainer = document.getElementById('clutch-dots');
    const cards = document.querySelectorAll('.clutch-card');
    
    if (!slider || !prevBtn || !nextBtn || !dotsContainer || cards.length === 0) return;

    let lastActiveIndex = 0;

    const getScrollAmount = () => {
      const firstCard = slider.firstElementChild as HTMLElement;
      return firstCard ? firstCard.offsetWidth + 24 : 360;
    };

    // FUNCIÓN CORREGIDA: Detecta cuántas tarjetas se ven según el breakpoint
    const getVisibleCardsCount = () => {
      if (window.innerWidth >= 1024) return 3; // Desktop (lg)
      if (window.innerWidth >= 640) return 2;  // Tablet (sm)
      return 1;                                // Mobile (Mantiene tu lógica intacta)
    };

    const renderDots = () => {
      dotsContainer.innerHTML = '';
      
      const visibleCards = getVisibleCardsCount();
      
      const totalDotsNeeded = visibleCards === 1 
        ? cards.length 
        : Math.max(1, cards.length - visibleCards + 1);

      if (totalDotsNeeded <= 1) {
        dotsContainer.classList.add('hidden');
        return;
      } else {
        dotsContainer.classList.remove('hidden');
      }

      for (let idx = 0; idx < totalDotsNeeded; idx++) {
        const dot = document.createElement('button');
        dot.className = `clutch-dot h-2.5 rounded-full transition-all duration-300 cursor-pointer ${idx === lastActiveIndex ? 'w-6 bg-[#0066cc]' : 'w-2.5 bg-gray-300'}`;
        dot.setAttribute('aria-label', `Go to slide ${idx + 1}`);
        dot.setAttribute('data-index', idx.toString());
        
        dot.addEventListener('click', () => {
          slider.scrollTo({
            left: idx * getScrollAmount(),
            behavior: 'smooth'
          });
        });
        
        dotsContainer.appendChild(dot);
      }
    };

    // Control dinámico del scroll
    slider.addEventListener('scroll', () => {
      const scrollLeft = slider.scrollLeft;
      const cardWidth = getScrollAmount();
      
      let activeIndex = Math.round(scrollLeft / cardWidth);
      
      const visibleCards = getVisibleCardsCount();
      
      if (visibleCards > 1) {
        const maxIndex = cards.length - visibleCards;
        if (activeIndex > maxIndex) activeIndex = maxIndex;
      }
      
      lastActiveIndex = activeIndex;

      const allDots = dotsContainer.querySelectorAll('.clutch-dot');
      allDots.forEach((dot, idx) => {
        if (idx === activeIndex) {
          dot.classList.remove('w-2.5', 'bg-gray-300');
          dot.classList.add('w-6', 'bg-[#0066cc]');
        } else {
          dot.classList.remove('w-6', 'bg-[#0066cc]');
          dot.classList.add('w-2.5', 'bg-gray-300');
        }
      });

      const maxScrollLeft = slider.scrollWidth - slider.clientWidth;
      prevBtn.disabled = scrollLeft <= 5;
      nextBtn.disabled = scrollLeft >= maxScrollLeft - 5;
    });

    nextBtn.addEventListener('click', () => {
      slider.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    prevBtn.addEventListener('click', () => {
      slider.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    let resizeTimeout: any;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        renderDots();
      }, 150);
    });

    renderDots();
    
    setTimeout(() => {
      const maxScrollLeft = slider.scrollWidth - slider.clientWidth;
      prevBtn.disabled = slider.scrollLeft <= 5;
      nextBtn.disabled = slider.scrollLeft >= maxScrollLeft - 5;
    }, 100);
  }

  initClutchSlider();
  document.addEventListener('astro:after-swap', initClutchSlider);
</script>