---
const reviews = [
  {
    rating: "5.0",
    text: "“They were well organized for the interview and onboarding process.”",
    author: "Physician",
    company: "Balance in Health"
  },
  {
    rating: "5.0",
    text: "“I feel like I have a true employee working with my company.”",
    author: "Owner & Marketing Strategist",
    company: "Ashley Melton Media"
  },
  {
    rating: "5.0",
    text: "“The team is very attentive to my needs.”",
    author: "Owner & Nurse Practitioner",
    company: "The WoundCare NP"
  },
  {
    rating: "5.0",
    text: "“I felt they understood my needs and did not hard sell me.”",
    author: "Director",
    company: "Hope Healthcares"
  }
];
---

<section class="w-full bg-[#FAF8F5] py-20 md:py-28 px-6 overflow-hidden border-b border-gray-100">
  <div class="mx-auto max-w-7xl">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <div class="flex flex-col gap-2">
        <h2 class="text-3xl md:text-5xl font-extrabold text-[#3d1d0e] tracking-tight">
          Client <span class="text-brand-green">Reviews</span>
        </h2>
        <div class="flex items-center gap-3 mt-2">
          <span class="font-bold text-[#3d1d0e] text-lg">Your Service Reviews</span>
          <span class="font-extrabold text-brand-green text-lg">4.8</span>
          <div class="flex text-amber-500 text-lg">★★★★★</div>
          <span class="text-gray-500 text-sm font-medium">189 reviews</span>
        </div>
      </div>
    </div>

    <div class="relative w-full md:px-12 group">
      
      <button 
        id="clutch-prev-btn" 
        class="absolute -left-2 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-700 shadow-md hover:bg-brand-blue hover:text-white transition-all duration-300 disabled:opacity-30 disabled:pointer-events-none"
        aria-label="Previous page"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>

      <div class="w-full overflow-hidden">
        <div 
          id="clutch-grid" 
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 transition-all duration-500"
        >
          {reviews.map((review, index) => (
            <div 
              class="clutch-card bg-white rounded-2xl p-8 border border-gray-100 shadow-sm flex flex-col justify-between gap-6 hover:shadow-md transition-all duration-300"
              data-index={index}
            >
              <div class="flex flex-col gap-4">
                <div class="flex items-center gap-2">
                  <span class="font-extrabold text-brand-green">{review.rating}</span>
                  <div class="flex text-amber-500 text-sm">★★★★★</div>
                </div>
                <p class="text-gray-600 font-medium text-base leading-relaxed">
                  {review.text}
                </p>
              </div>
              
              <div class="border-t border-gray-100 pt-4 flex flex-col">
                <span class="font-bold text-[#3d1d0e] text-sm">{review.author}</span>
                <span class="text-gray-400 text-xs font-semibold">{review.company}</span>
                <div class="flex items-center gap-1.5 text-brand-green text-xs font-bold mt-3">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                    <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-7.446-2.15a.75.75 0 00-1.064-1.054L6.16 11.18l-.947-.948a.75.75 0 10-1.06 1.06l1.477 1.477a.75.75 0 001.06 0l2.266-2.265z" clip-rule="evenodd" />
                  </svg>
                  Verified Review
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <button 
        id="clutch-next-btn" 
        class="absolute -right-2 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-700 shadow-md hover:bg-brand-blue hover:text-white transition-all duration-300 disabled:opacity-30 disabled:pointer-events-none"
        aria-label="Next page"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>

      <div id="clutch-dots" class="flex justify-center items-center gap-2 mt-8"></div>

    </div>

  </div>
</section>

<script>
  function initClutchSlider() {
    const prevBtn = document.getElementById('clutch-prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('clutch-next-btn') as HTMLButtonElement;
    const dotsContainer = document.getElementById('clutch-dots');
    const cards = document.querySelectorAll('.clutch-card') as NodeListOf<HTMLElement>;
    
    if (!prevBtn || !nextBtn || !dotsContainer || cards.length === 0) return;

    let page = 0;

    function getItemsPerPage() {
      if (window.innerWidth >= 1024) return 3; // Desktop
      if (window.innerWidth >= 640) return 2;  // Tablet
      return 1;                                // Mobile
    }

    function getTotalPages() {
      return Math.ceil(cards.length / getItemsPerPage());
    }

    // Renderiza los puntos de forma dinámica según las páginas calculadas
    function updateDots() {
      if (!dotsContainer) return;
      dotsContainer.innerHTML = '';
      const totalPages = getTotalPages();

      // Si todo cabe en una sola pantalla, ocultamos los dots y las flechas
      if (totalPages <= 1) {
        prevBtn.style.display = 'none';
        nextBtn.style.display = 'none';
        return;
      } else {
        prevBtn.style.display = 'flex';
        nextBtn.style.display = 'flex';
      }

      for (let i = 0; i < totalPages; i++) {
        const dot = document.createElement('button');
        
        // Estilo expandido tipo cápsula si es el punto activo (como en Clutch)
        if (i === page) {
          dot.className = 'w-5 h-2 rounded-full bg-brand-blue transition-all duration-300';
        } else {
          dot.className = 'w-2 h-2 rounded-full bg-gray-300 hover:bg-gray-400 transition-all duration-300';
        }
        
        dot.setAttribute('aria-label', `Go to page ${i + 1}`);
        dot.addEventListener('click', () => {
          page = i;
          updateView();
        });
        
        dotsContainer.appendChild(dot);
      }
    }

    function updateView() {
      const itemsPerPage = getItemsPerPage();
      const maxPages = getTotalPages() - 1;

      if (page > maxPages) page = maxPages;
      if (page < 0) page = 0;

      const startIndex = page * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;

      // Filtrar visibilidad de tarjetas
      cards.forEach((card, idx) => {
        if (idx >= startIndex && idx < endIndex) {
          card.style.display = 'flex';
          // Pequeño timeout para suavizar la transición de opacidad
          setTimeout(() => card.style.opacity = '1', 10);
        } else {
          card.style.display = 'none';
          card.style.opacity = '0';
        }
      });

      // Actualizar estado de las flechas y repintar los dots
      prevBtn.disabled = page === 0;
      nextBtn.disabled = page >= maxPages;
      
      updateDots();
    }

    nextBtn.addEventListener('click', () => {
      page++;
      updateView();
    });

    prevBtn.addEventListener('click', () => {
      page--;
      updateView();
    });

    // Escuchar el cambio de tamaño de pantalla para recalcular columnas y dots
    window.addEventListener('resize', updateView);
    updateView();
  }

  // Inicialización compatible con ciclos SPA e hidratación parcial en Astro
  initClutchSlider();
  document.addEventListener('astro:after-swap', initClutchSlider);
</script>