---
interface FAQType {
  title: string;
  description: string;
  questions: {
    question: string;
    answer: string;
  }[]
}

const FAQs: FAQType = Astro.props.FAQs;
---

{/* Añadimos la clase controladora 'faq-scroll-trigger' */}
<section class="w-full bg-[#FAF8F5] py-20 md:py-28 px-6 border-b border-gray-100 faq-scroll-trigger">
  <div class="mx-auto max-w-4xl flex flex-col items-center">
    
    {/* TÍTULO Y DESCRIPCIÓN: Conectados a la animación de fade-in */}
    <div class="text-center max-w-2xl mb-16 flex flex-col gap-4 faq-title-fade">
      <h2 class="text-3xl md:text-5xl font-extrabold text-[#3d1d0e] tracking-tight leading-tight">
        {FAQs.title} <span class="text-brand-green">FAQs</span>
      </h2>
      <p class="text-gray-500 font-medium text-base md:text-2xl">
        {FAQs.description}
      </p>
    </div>

    <div class="w-full flex flex-col gap-4">
      {FAQs.questions.map((faq, index) => (
        <details 
          class="group bg-white rounded-2xl border border-gray-100 shadow-sm transition-all duration-300 [&_summary::-webkit-details-marker]:hidden open:shadow-md faq-item-slide"
          style={`transition-delay: ${index * 0.1}s`}>
          <summary class="flex items-center justify-between p-6 md:p-8 cursor-pointer select-none list-none gap-4">
            <h3 class="text-base md:text-2xl font-bold text-[#3d1d0e] group-hover:text-brand-green transition-colors duration-200 tracking-tight">
              {faq.question}
            </h3>
            
            <div class="shrink-0 p-1.5 rounded-full bg-gray-50 text-[#3d1d0e] group-open:bg-brand-blue group-open:text-white transition-all duration-300">
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                fill="none" 
                viewBox="0 0 24 24" 
                stroke-width="2.5" 
                stroke="currentColor" 
                class="w-6 h-6 transform transition-transform duration-300 group-open:rotate-180"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </div>
          </summary>

          <div class="px-6 md:px-8 pb-6 md:pb-8 border-t border-gray-50 pt-4">
            <p class="text-gray-600 text-sm md:text-xl leading-relaxed font-medium">
              {faq.answer}
            </p>
            
            <div class="flex items-center gap-1.5 text-brand-green text-md font-bold mt-4">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-green"></span>
              Your Service Verified Info
            </div>
          </div>

        </details>
      ))}
    </div>

  </div>
</section>

<script>
  function setupFAQAnimation() {
    const section = document.querySelector('.faq-scroll-trigger');
    if (!section) return;

    function checkScroll() {
      // Punto de disparo exacto al 30% del viewport
      const triggerPoint = window.innerHeight - (window.innerHeight * 0.30);
      const sectionTop = section!.getBoundingClientRect().top;

      if (sectionTop < triggerPoint) {
        section!.classList.add('is-visible');
        // Una vez visible, removemos el listener para optimizar rendimiento
        window.removeEventListener('scroll', checkScroll);
      }
    }

    window.addEventListener('scroll', checkScroll);
    checkScroll();
  }

  // Ejecución segura en el ciclo de vida del DOM
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupFAQAnimation);
  } else {
    setupFAQAnimation();
  }
  document.addEventListener('astro:page-load', setupFAQAnimation);
</script>

<style>
  /* --- ESTADO INICIAL (Ocultos por defecto) --- */
  
  /* El bloque del título se desvanece subiendo suavemente */
  .faq-title-fade {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  /* Las preguntas nacen corridas a la izquierda */
  .faq-item-slide {
    opacity: 0;
    transform: translateX(-40px);
    transition: opacity 1.2s ease-out, transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  /* --- ESTADO ACTIVO (Cuando entra al 30% del Viewport) --- */
  
  .faq-scroll-trigger.is-visible .faq-title-fade {
    opacity: 1;
    transform: translateY(0);
  }

  .faq-scroll-trigger.is-visible .faq-item-slide {
    opacity: 1;
    transform: translateX(0);
  }
</style>