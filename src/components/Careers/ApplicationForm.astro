---
---

<section id="aplication" class="w-full bg-white py-20 px-6 md:py-28 md:px-12 text-[#3d1d0e]">
  <div class="max-w-3xl mx-auto bg-white rounded-3xl border border-gray-100 shadow-md p-8 md:p-12">
    
    <div class="mb-10 text-center md:text-left">
      <span class="text-brand-green font-black uppercase tracking-widest text-xs block mb-2">
        Join Our Team
      </span>
      <h2 class="text-3xl md:text-4xl font-black tracking-tight text-[#3d1d0e]">
        Submit Your Application
      </h2>
      <p class="text-gray-500 text-sm font-medium mt-2">
        Complete the form below. All fields marked with an asterisk (<span class="text-red-500">*</span>) are strictly required.
      </p>
    </div>

    <form action="#" method="POST" enctype="multipart/form-data" class="flex flex-col gap-8">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col gap-2">
          <label for="fullname" class="text-sm font-extrabold tracking-wide uppercase text-[#3d1d0e]">
            Full Name <span class="text-red-500">*</span>
          </label>
          <input 
            type="text" 
            id="fullname" 
            name="fullname" 
            required 
            placeholder="John Doe"
            class="w-full bg-[#FAF8F5] border border-gray-200/80 rounded-xl px-5 py-4 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden focus:border-brand-blue focus:bg-white transition-all duration-200"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="phone" class="text-sm font-extrabold tracking-wide uppercase text-[#3d1d0e]">
            Phone Number <span class="text-red-500">*</span>
          </label>
          <input 
            type="tel" 
            id="phone" 
            name="phone" 
            required 
            placeholder="+1 (555) 000-0000"
            class="w-full bg-[#FAF8F5] border border-gray-200/80 rounded-xl px-5 py-4 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden focus:border-brand-blue focus:bg-white transition-all duration-200"
          />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label for="email" class="text-sm font-extrabold tracking-wide uppercase text-[#3d1d0e]">
          Email Address <span class="text-red-500">*</span>
        </label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required 
          placeholder="johndoe@example.com"
          class="w-full bg-[#FAF8F5] border border-gray-200/80 rounded-xl px-5 py-4 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden focus:border-brand-blue focus:bg-white transition-all duration-200"
        />
      </div>

      <div class="flex flex-col gap-3 bg-[#FAF8F5] p-6 rounded-2xl border border-gray-100">
        <div class="flex justify-between items-center">
          <label for="experience-slider" class="text-sm font-extrabold tracking-wide uppercase text-[#3d1d0e]">
            Years of Experience
          </label>
          <span id="slider-value" class="bg-brand-blue text-white text-xs font-black px-3 py-1.5 rounded-lg min-w-12 text-center">
            0 years
          </span>
        </div>
        <input 
          type="range" 
          id="experience-slider" 
          name="years_experience" 
          min="0" 
          max="20" 
          value="0"
          class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-brand-blue"
        />
        <div class="flex justify-between text-[11px] font-bold text-gray-400 uppercase tracking-wider px-1">
          <span>0 yrs</span>
          <span>10 yrs</span>
          <span>20+ yrs</span>
        </div>
      </div>

      {/* Descripción de Experiencia */}
      <div class="flex flex-col gap-2">
        <label for="experience_description" class="text-sm font-extrabold tracking-wide uppercase text-[#3d1d0e]">
          Experience Description
        </label>
        <textarea 
          id="experience_description" 
          name="experience_description" 
          rows="4" 
          placeholder="Briefly describe your core expertise, past roles, or industries you've mastered..."
          class="w-full bg-[#FAF8F5] border border-gray-200/80 rounded-xl px-5 py-4 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden focus:border-brand-blue focus:bg-white transition-all duration-200 resize-none"
        ></textarea>
      </div>

      {/* Subir CV */}
      <div class="flex flex-col gap-2">
        <label class="text-sm font-extrabold tracking-wide uppercase text-[#3d1d0e]">
          Upload CV / Resume <span class="text-red-500">*</span>
        </label>
        <div class="relative w-full border-2 border-dashed border-gray-200 hover:border-brand-blue/60 bg-[#FAF8F5] rounded-xl transition-all duration-200 group">
          <input 
            type="file" 
            id="cv-file" 
            name="cv" 
            required 
            accept=".pdf,.doc,.docx"
            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
          />
          <div class="flex flex-col items-center justify-center py-6 px-4 text-center gap-2 pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8 text-gray-400 group-hover:text-brand-blue transition-colors duration-200">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
            </svg>
            <p id="file-name-text" class="text-sm font-bold text-[#3d1d0e]">
              Click to upload or drag & drop
            </p>
            <p class="text-xs text-gray-400 font-medium">
              PDF, DOC, or DOCX up to 5MB
            </p>
          </div>
        </div>
      </div>

      {/* Link de Vocaroo + Explicación */}
      <div class="flex flex-col gap-3">
        <div class="flex flex-col gap-1">
          <label for="vocaroo_link" class="text-sm font-extrabold tracking-wide uppercase text-[#3d1d0e]">
            Vocaroo Audio Introduction Link <span class="text-red-500">*</span>
          </label>
          <input 
            type="url" 
            id="vocaroo_link" 
            name="vocaroo_link" 
            required 
            placeholder="https://vocaroo.com/..."
            class="w-full bg-[#FAF8F5] border border-gray-200/80 rounded-xl px-5 py-4 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden focus:border-brand-blue focus:bg-white transition-all duration-200"
          />
        </div>
        
        {/* Info Box Vocaroo */}
        <div class="bg-brand-blue/5 border border-brand-blue/10 rounded-2xl p-4 flex gap-3 items-start">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-brand-blue shrink-0 mt-0.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 111.063 1.06l-.041.02a.75.75 0 01-1.063-1.06zm0 4.5l.041-.02a.75.75 0 111.063 1.06l-.041.02a.75.75 0 01-1.063-1.06zM12 22.5c5.799 0 10.5-4.701 10.5-10.5S17.299 1.5 12 1.5 1.5 6.201 1.5 12 6.201 22.5 12 22.5z" />
          </svg>
          <div class="text-xs leading-relaxed text-gray-600 font-medium">
            <strong class="text-[#3d1d0e] font-extrabold">What is Vocaroo?</strong> It's a free web service to record voice notes. Go to <a href="https://vocaroo.com/" target="_blank" rel="noopener noreferrer" class="text-brand-blue font-extrabold underline hover:text-brand-green transition-colors duration-200">vocaroo.com</a> to record your presentation or upload an audio file directly, then copy and paste the generated share link right here.
          </div>
        </div>
      </div>

      {/* Botón Submit */}
      <button 
        type="submit" 
        class="w-full text-center bg-brand-blue text-white font-extrabold px-8 py-4 rounded-xl hover:bg-brand-green transition-all duration-200 shadow-xs uppercase tracking-wider text-sm mt-2 cursor-pointer"
      >
        Submit Application
      </button>

    </form>
  </div>
</section>

<script>
  /**
   * FUNCIÓN DE ENVÍO DE DATOS (Maneja la lógica de negocio / Fetch API)
   * Recibe un objeto FormData con toda la información ya recolectada.
   */
  async function sendApplicationData(formData: FormData): Promise<{ success: boolean; error?: string }> {
    // --- CONSULTA EN CONSOLA (Verificación del Payload) ---
    console.log('🚀 [Data Collected] Sending payload...');
    for (let [key, value] of formData.entries()) {
      if (value instanceof File) {
        console.log(`🔹 ${key}: Archivo -> ${value.name} (${value.size} bytes)`);
      } else {
        console.log(`🔹 ${key}: ${value}`);
      }
    }

    try {
      // Simulación de latencia de red (2 segundos)
      await new Promise((resolve) => setTimeout(resolve, 2000));

      /* INTEGRACIÓN FUTURA DE BACKEND:
        Aquí es donde conectarás tu API route de Astro, Webhook o CRM.
        
        const response = await fetch('/api/apply', {
          method: 'POST',
          body: formData // Envía el FormData directamente (Mantiene codificación multipart/form-data)
        });
        
        if (!response.ok) {
          throw new Error('Server responded with an error status');
        }
      */

      return { success: true };
    } catch (error: any) {
      console.error('❌ Error in sendApplicationData:', error);
      return { success: false, error: error?.message || 'Unknown network error' };
    }
  }

  /**
   * INICIALIZADOR DE INTERFAZ DE USUARIO (UX)
   */
  function initFormUX() {
    // 1. Slider interactivo
    const slider = document.getElementById('experience-slider') as HTMLInputElement;
    const sliderValue = document.getElementById('slider-value');

    if (slider && sliderValue) {
      const updateValue = () => {
        const val = slider.value;
        sliderValue.textContent = val === "1" ? "1 year" : `${val} years`;
      };
      slider.addEventListener('input', updateValue);
    }

    // 2. Feedback visual del CV adjuntado
    const fileInput = document.getElementById('cv-file') as HTMLInputElement;
    const nameText = document.getElementById('file-name-text');

    if (fileInput && nameText) {
      fileInput.addEventListener('change', () => {
        const files = fileInput.files;
        if (files && files.length > 0) {
          nameText.textContent = `Selected: ${files[0].name}`;
          nameText.classList.add('text-brand-green');
        } else {
          nameText.textContent = 'Click to upload or drag & drop';
          nameText.classList.remove('text-brand-green');
        }
      });
    }

    // 3. Manejador del Evento Submit (UI Controller)
    const form = document.querySelector('form');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault(); // Detener recarga de página por defecto

        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalBtnText = submitBtn ? submitBtn.textContent : 'Submit Application';

        // Deshabilitar botón y mostrar estado de carga
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending Application...';
          submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
        }

        // --- RECOLECCIÓN AUTOMÁTICA DE DATOS ---
        // FormData extrae los valores actuales usando el atributo 'name' de cada input
        const collectedData = new FormData(form);

        // --- INVOCACIÓN DE LA FUNCIÓN DE ENVÍO INDEPENDIENTE ---
        const result = await sendApplicationData(collectedData);

        // --- RESPUESTA VISUAL SEGÚN EL RESULTADO ---
        if (result.success) {
          alert('¡Application submitted successfully! Thank you for your interest.');
          form.reset();
          
          // Resetear estados visuales de los inputs dinámicos
          if (sliderValue) sliderValue.textContent = '0 years';
          if (nameText) {
            nameText.textContent = 'Click to upload or drag & drop';
            nameText.classList.remove('text-brand-green');
          }
        } else {
          alert(`An error occurred while sending your application: ${result.error}`);
        }

        // Restaurar estado original del botón
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
          submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        }
      });
    }
  }

  // Soporte SPA de Astro y cargas tradicionales del navegador
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFormUX);
  } else {
    initFormUX();
  }
  document.addEventListener('astro:page-load', initFormUX);
</script>