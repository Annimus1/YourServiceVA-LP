---
interface Talent {
  name: string;
  role: string;
  image: string;
  tags: string[];
}

const talents: Talent[] = [
  {
    name: "Olivia Sanders",
    role: "Bookkeeping Assistant",
    image: "https://cdn.prod.website-files.com/6880b79a825dc00d03bc2ee6/688736829fd6aa88db2cd37b_136d37611ef6b44299697f10d985b09f_card-image1.webp", // Asegúrate de colocar las imágenes en tu carpeta public
    tags: ["QuickBooks", "Invoicing", "Accounts Payable", "Bank Reconciliation", "Financial Reports"]
  },
  {
    name: "Maya Rodriguez",
    role: "Executive Virtual Assistant",
    image: "https://cdn.prod.website-files.com/6880b79a825dc00d03bc2ee6/68875c73cb78f539bf9f5b3f_Frame%205209%20(1).webp",
    tags: ["Calendar Management", "Inbox Management", "Travel Coordination", "Client Communication", "CRM Tools"]
  },
  {
    name: "Daniel Kim",
    role: "Customer Support Specialist",
    image: "https://cdn.prod.website-files.com/6880b79a825dc00d03bc2ee6/68875c9136c294a71517098c_Frame%205209%20(2).webp",
    tags: ["Email Support", "Live Chat", "Zendesk", "Troubleshooting", "Customer Retention"]
  },
  {
    name: "Maya Rodriguez",
    role: "Executive Virtual Assistant",
    image: "https://cdn.prod.website-files.com/6880b79a825dc00d03bc2ee6/68875cfd26c4ff9d6660d8bb_Frame%205209%20(3).webp",
    tags: ["Calendar Management", "Inbox Management", "Travel Coordination", "Client Communication", "CRM Tools"]
  },
  {
    name: "Maya Rodriguez",
    role: "Executive Virtual Assistant",
    image: "https://cdn.prod.website-files.com/6880b79a825dc00d03bc2ee6/68875c73cb78f539bf9f5b3f_Frame%205209%20(1).webp",
    tags: ["Calendar Management", "Inbox Management", "Travel Coordination", "Client Communication", "CRM Tools"]
  },
];
---

<section class="bg-[#FAF8F5] py-20 px-6 md:px-12 w-full text-[#3d1d0e] overflow-hidden">
  <div class="max-w-7xl mx-auto flex flex-col gap-12 relative">
    
    <div class="text-center flex flex-col gap-4 max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-5xl font-black tracking-tight leading-tight">
        Work With a Virtual Assistant Company That Pre-trains VAs to Meet Your Needs
      </h2>
      <p class="text-gray-500 font-medium text-base md:text-lg leading-relaxed">
        All Yourserviceva virtual assistants are pre-trained and vetted for your business.
      </p>
    </div>

    <div class="relative w-full group/slider">
            <div 
        id="talent-slider"
        class="flex flex-row overflow-x-auto flex-nowrap gap-6 pb-8 snap-x snap-mandatory scroll-smooth [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      >
        {talents.map((talent) => (
          <div class="w-[290px] sm:w-[320px] flex-shrink-0 bg-white rounded-2xl border border-gray-100/70 shadow-sm p-4 flex flex-col gap-4 snap-start transition-all duration-300 hover:shadow-md">
            
            <div class="w-full aspect-[4/3] rounded-xl overflow-hidden bg-gray-50 relative">
              <img 
                src={talent.image} 
                alt={talent.name}
                class="w-full h-full object-cover object-top"
                loading="lazy"
              />
            </div>

            <div class="flex flex-col gap-2 flex-grow">
              <div class="inline-flex items-center gap-1.5 self-start bg-emerald-50 text-emerald-600 px-2.5 py-1 rounded-md text-[11px] font-extrabold uppercase tracking-wide border border-emerald-100/50">
                <svg class="w-3 h-3 fill-emerald-500" viewBox="0 0 24 24">
                  <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                Verified Expert
              </div>

              <div class="mt-1">
                <h3 class="text-lg font-black text-[#3d1d0e] tracking-tight">{talent.name}</h3>
                <p class="text-sm font-semibold text-gray-400">{talent.role}</p>
              </div>

              <div class="flex flex-wrap gap-1.5 mt-3">
                {talent.tags.map((tag) => (
                  <span class="bg-[#FAF8F5] text-gray-600 px-2.5 py-1 rounded-full text-xs font-semibold border border-gray-100">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

          </div>
        ))}
      </div>

      <button 
        id="prev-btn"
        class="hidden md:flex absolute left-[-20px] top-1/2 transform -translate-y-1/2 w-12 h-12 rounded-full bg-white shadow-lg border border-gray-100 items-center justify-center cursor-pointer transition-all hover:scale-105 z-20"
        aria-label="Previous slide"
      >
        <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <button 
        id="next-btn"
        class="hidden md:flex absolute right-[-20px] top-1/2 transform -translate-y-1/2 w-12 h-12 rounded-full bg-white shadow-lg border border-gray-100 items-center justify-center cursor-pointer transition-all hover:scale-105 z-20"
        aria-label="Next slide"
      >
        <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
      
    </div>

  </div>
</section>

<script>
  const setupSlider = () => {
    const slider = document.getElementById('talent-slider');
    const nextBtn = document.getElementById('next-btn');
    const prevBtn = document.getElementById('prev-btn');

    if (!slider || !nextBtn || !prevBtn) return;

    // Calculamos cuánto avanzar (ancho de una tarjeta + el gap)
    const getScrollAmount = () => {
      const firstCard = slider.firstElementChild as HTMLElement;
      if (firstCard) {
        return firstCard.offsetWidth + 24; // 24px es el equivalente a gap-6
      }
      return 344;
    };

    // Eventos de los botones
    nextBtn.addEventListener('click', () => {
      slider.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    prevBtn.addEventListener('click', () => {
      slider.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    // Opcional: Ocultar o mostrar la flecha izquierda según la posición del scroll
    slider.addEventListener('scroll', () => {
      if (slider.scrollLeft > 10) {
        prevBtn.classList.remove('md:hidden');
      } else {
        prevBtn.classList.add('md:hidden');
      }
    });
  };

  // Se ejecuta en la carga inicial y es compatible con transiciones de Astro (ViewTransitions)
  setupSlider();
  document.addEventListener('astro:after-swap', setupSlider);
</script>