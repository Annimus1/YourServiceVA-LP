---
interface Props {
  service?: string;
  industry?: string;
  plan?: string;
  anual?: string;
}

// 1. Intentar leer de Props, si no, capturar directamente de los SearchParams de la URL
const service = Astro.props.service || Astro.url.searchParams.get('service') || '';
const industry = Astro.props.industry || Astro.url.searchParams.get('industry') || '';
const plan = Astro.props.plan || Astro.url.searchParams.get('plan') || '';
const anual = Astro.props.anual || Astro.url.searchParams.get('anual') || '';

const isAnualInitial = anual === 'Y';

const services = [
  { value: "customer-service", label: "Customer Service" },
  { value: "human-resources", label: "Human Resources" },
  { value: "inside-sales", label: "Inside Sales Agent" },
  { value: "intake-specialist", label: "Intake Specialist" },
  { value: "lead-generation", label: "Lead Generation" },
  { value: "predictive-dialer", label: "Predictive Dialer" },
  { value: "tech-support", label: "Tech Support" },
  { value: "virtual-assistants", label: "Virtual Assistants" }
];

const industries = [
  { value: "finance", label: "Finance" },
  { value: "healthcare", label: "Healthcare" },
  { value: "home-improvement", label: "Home Improvement" },
  { value: "legal", label: "Legal" },
  { value: "real-estate", label: "Real Estate" },
  { value: "solar", label: "Solar" },
  { value: "other", label: "Other (Please specify)" }
];

// Alineado con los datos comerciales exactos provistos
const dialerPlans = [
  { value: "starter", labelMonthly: "Starter Plan ($80/mo)", labelAnual: "Starter Plan ($64/mo - Billed Annually)" },
  { value: "premium", labelMonthly: "Premium Plan ($140/mo)", labelAnual: "Premium Plan ($112/mo - Billed Annually)" },
  { value: "enterprise", labelMonthly: "Enterprise Plan ($180/mo)", labelAnual: "Enterprise Plan ($144/mo - Billed Annually)" }
];

const countryCodes = [
  { code: "+1", flag: "🇺🇸", label: "USA/CA", id: "US" },
  { code: "+58", flag: "🇻🇪", label: "VE", id: "VE" },
  { code: "+44", flag: "🇬🇧", label: "UK", id: "UK" },
  { code: "+61", flag: "🇦🇺", label: "AU", id: "AU" },
  { code: "+34", flag: "🇪🇸", label: "ES", id: "ES" },
  { code: "+52", flag: "🇲🇽", label: "MX", id: "MX" },
  { code: "+57", flag: "🇨🇴", label: "CO", id: "CO" },
  { code: "+54", flag: "🇦🇷", label: "AR", id: "AR" },
  { code: "+56", flag: "🇨🇱", label: "CL", id: "CL" },
  { code: "+51", flag: "🇵🇪", label: "PE", id: "PE" }
];

const isDialerActive = service === 'predictive-dialer';
const isOtherIndustryActive = industry === 'other';
---

<section id="contact-section" class="w-full bg-white py-20 px-6 md:py-28 md:px-12 text-[#3d1d0e] overflow-hidden">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
    
    <div class="lg:col-span-5 flex flex-col gap-10 scroll-reveal">
      <div>
        <span class="text-brand-green font-black uppercase tracking-widest text-xs md:text-md block mb-2">
          Get in Touch
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight leading-tight text-[#3d1d0e]">
          Let’s Build Your Remote Operations.
        </h2>
        <p class="text-gray-600 text-sm sm:text-base font-medium mt-3 leading-relaxed">
          Have questions about pricing, compliance, or infrastructure setup? Drop us a message and our operational team will reach out within 24 hours.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 border-y border-gray-100 py-8">
        <div class="flex flex-col items-center gap-3 text-center">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-brand-blue">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z" />
            </svg>
            <h3 class="text-lg font-black text-[#3d1d0e]">Sales</h3>
          </div>
          <p class="text-gray-500 text-xs font-medium leading-relaxed">
            Want to speak with our team directly?
          </p>
          <a href="https://calendar.app.google/yxWAZB4xdo6yx2mD8" target="_blank" rel="noopener noreferrer" class="mt-2 bg-brand-blue text-white text-xs font-black px-4 py-2.5 rounded-lg hover:bg-brand-green transition-all duration-200 uppercase tracking-wider shadow-2xs hover:scale-105 transform dynamic-btn">
            Book a Free Discovery Call
          </a>
        </div>

        <div class="flex flex-col items-center gap-3 text-center">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-brand-blue">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75 16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z" />
            </svg>
            <h3 class="text-lg font-black text-[#3d1d0e]">Support</h3>
          </div>
          <p class="text-gray-500 text-xs font-medium leading-relaxed">
            Need Help?
          </p>
          <a href="/services/predictive-dialer-software#Dialer-tutos" class="flex items-center justify-center gap-2 mt-2 border border-gray-200 text-brand-dark-blue bg-brand-green hover:border-brand-green text-xs font-black px-4 py-2.5 rounded-lg transition-all duration-200 uppercase tracking-wider hover:scale-105 transform dynamic-btn">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
            Dialer Tutorials
          </a>
          <a href="mailto:Sales@yourserviceva.com" class="mt-2 bg-transparent flex items-center justify-center gap-2 border border-gray-200 text-[#3d1d0e] hover:border-brand-blue hover:text-brand-blue text-xs font-black px-4 py-2.5 rounded-lg transition-all duration-200 uppercase tracking-wider hover:scale-105 transform dynamic-btn">
            <svg class="inline w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            Get Help
          </a>
        </div>
      </div>

      <div class="bg-[#FAF8F5] rounded-3xl p-6 md:p-8 border border-gray-100 shadow-2xs">
        <div class="flex gap-1 mb-4 text-amber-500">
          {[...Array(5)].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-4 h-4">
              <path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.787 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.132 9.21l8.2-1.192L12 .587z"/>
            </svg>
          ))}
          <span class="text-xs md:text-md font-black text-[#3d1d0e] ml-2">4.9 / 5.0</span>
        </div>
        <p class="text-gray-600 text-sm font-medium leading-relaxed italic mb-4">
          "I was initially skeptical about the process and the Virtual Assistant's ability to help my business. However, from the start, my account manager lined up some amazing candidates..."
        </p>
        <div>
          <h4 class="text-sm font-extrabold text-[#3d1d0e]">John Dostaler</h4>
          <p class="text-xs md:text-md text-gray-400 font-bold uppercase tracking-wider mt-0.5">Hospitality & Travel</p>
        </div>
      </div>
    </div>

    <div class="lg:col-span-7 w-full bg-[#FAF8F5] rounded-3xl border border-gray-100 shadow-2xs p-8 md:p-12 scroll-reveal scroll-reveal-delayed">
      <form id="business-contact-form" class="flex flex-col gap-6">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="contact-first-name" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
              First Name <span class="text-[#FF6B4A]">*</span>
            </label>
            <input 
              type="text" id="contact-first-name" name="first_name" required placeholder="Alexander"
              class="w-full bg-white border border-gray-200/80 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden focus:border-brand-blue transition-all duration-200 focus:scale-[1.01] transform"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="contact-last-name" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
              Last Name <span class="text-[#FF6B4A]">*</span>
            </label>
            <input 
              type="text" id="contact-last-name" name="last_name" required placeholder="Wright"
              class="w-full bg-white border border-gray-200/80 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden focus:border-brand-blue transition-all duration-200 focus:scale-[1.01] transform"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="contact-email" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
              Business Email <span class="text-[#FF6B4A]">*</span>
            </label>
            <input 
              type="email" id="contact-email" name="email" required placeholder="alex@company.com"
              class="w-full bg-white border border-gray-200/80 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden focus:border-brand-blue transition-all duration-200 focus:scale-[1.01] transform"
            />
          </div>
          
          <div class="flex flex-col gap-2">
            <label for="contact-phone" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
              Phone Number <span class="text-[#FF6B4A]">*</span>
            </label>
            <div class="flex bg-white border border-gray-200/80 rounded-xl focus-within:border-brand-blue focus-within:scale-[1.01] transition-all duration-200 overflow-hidden transform">
              <select 
                id="contact-country-code"
                name="country_code" 
                aria-label="Country Code"
                class="bg-[#FAF8F5] border-r border-gray-200 px-3 text-sm font-bold text-[#3d1d0e] focus:outline-hidden cursor-pointer"
              >
                {countryCodes.map(c => (
                  <option value={c.code} data-country-id={c.id}>
                    {c.flag} {c.code}
                  </option>
                ))}
              </select>
              <input 
                type="tel" id="contact-phone" name="phone" required placeholder="Phone Number"
                class="w-full bg-white px-4 py-3.5 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden"
              />
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="contact-company" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
            Company Name <span class="text-[#FF6B4A]">*</span>
          </label>
          <input 
            type="text" id="contact-company" name="company_name" required placeholder="Acme Logistics LLC"
            class="w-full bg-white border border-gray-200/80 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden focus:border-brand-blue transition-all duration-200 focus:scale-[1.01] transform"
          />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="contact-service" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
              Core Service Needed <span class="text-[#FF6B4A]">*</span>
            </label>
            <select 
              id="contact-service" name="service" required
              class="w-full bg-white border border-gray-200/80 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] focus:outline-hidden focus:border-brand-blue transition-all duration-200 cursor-pointer"
            >
              <option value="" disabled selected={!service}>Select a service</option>
              {services.map(s => (
                <option value={s.value} selected={service === s.value}>{s.label}</option>
              ))}
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label for="contact-industry" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
              Industry <span class="text-[#FF6B4A]">*</span>
            </label>
            <select 
              id="contact-industry" name="industry" required
              class="w-full bg-white border border-gray-200/80 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] focus:outline-hidden focus:border-brand-blue transition-all duration-200 cursor-pointer"
            >
              <option value="" disabled selected={!industry}>Select your industry</option>
              {industries.map(i => (
                <option value={i.value} selected={industry === i.value}>{i.label}</option>
              ))}
            </select>
          </div>
        </div>

        <div 
          id="plan-wrapper" 
          style={{ display: isDialerActive ? 'flex' : 'none' }}
          class={`flex-col gap-4 bg-white border border-gray-100 rounded-2xl p-5 shadow-2xs transition-all duration-300 transform ${isDialerActive ? 'scale-100 opacity-100' : 'scale-95 opacity-0'}`}
        >
          <div class="flex flex-col gap-2">
            <span class="text-xs font-black tracking-wide uppercase text-[#3d1d0e]">Billing Cycle</span>
            <div class="grid grid-cols-2 bg-[#FAF8F5] p-1 rounded-xl border border-gray-200/60 max-w-xs relative">
              <label class="flex justify-center items-center gap-1.5 py-2 px-3 rounded-lg text-xs font-black uppercase tracking-wider cursor-pointer transition-all duration-200 text-center select-none z-10 native-tab">
                <input type="radio" name="billing_cycle" value="monthly" class="hidden" checked={!isAnualInitial} />
                <span class="tab-text">Monthly</span>
              </label>
              <label class="flex justify-center items-center gap-1.5 py-2 px-3 rounded-lg text-xs font-black uppercase tracking-wider cursor-pointer transition-all duration-200 text-center select-none z-10 native-tab">
                <input type="radio" name="billing_cycle" value="annually" class="hidden" checked={isAnualInitial} />
                <span class="tab-text">Annually</span>
                <span class="bg-brand-green text-white text-[9px] px-1.5 py-0.5 rounded-sm scale-95 origin-right font-black">Save</span>
              </label>
              <div class="absolute top-1 bottom-1 left-1 w-[calc(50%-4px)] bg-white rounded-lg shadow-2xs transition-transform duration-300 ease-out border border-gray-100 tab-slider"></div>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="contact-plan" class="text-xs md:text-md font-black tracking-wide uppercase text-brand-blue">
              Select Dialer Infrastructure Plan <span class="text-[#FF6B4A]">*</span>
            </label>
            <select 
              id="contact-plan" name="plan"
              required={isDialerActive}
              class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] focus:outline-hidden focus:border-brand-blue transition-all duration-200 cursor-pointer"
            >
              <option value="" disabled selected={!plan}>Select your dialer tiered plan</option>
              {dialerPlans.map(p => (
                <option 
                  value={p.value} 
                  selected={plan === p.value}
                  data-label-monthly={p.labelMonthly}
                  data-label-anual={p.labelAnual}
                >
                  {isAnualInitial ? p.labelAnual : p.labelMonthly}
                </option>
              ))}
            </select>
          </div>
        </div>

        <div 
          id="custom-industry-wrapper" 
          style={{ display: isOtherIndustryActive ? 'flex' : 'none' }}
          class={`flex-col gap-2 transition-all duration-300 transform ${isOtherIndustryActive ? 'scale-100 opacity-100' : 'scale-95 opacity-0'}`}
        >
          <label for="contact-custom-industry" class="text-xs md:text-md font-black tracking-wide uppercase text-brand-blue">
            Please specify your industry <span class="text-[#FF6B4A]">*</span>
          </label>
          <input 
            type="text" id="contact-custom-industry" name="custom_industry" placeholder="E.g., Logistics, Operations..."
            required={isOtherIndustryActive}
            class="w-full bg-white border border-brand-blue/30 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] focus:outline-hidden focus:border-brand-blue transition-all duration-200"
          />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="contact-agents" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
              Number of Staff / Agents <span class="text-[#FF6B4A]">*</span>
            </label>
            <select 
              id="contact-agents" name="agent_count" required
              class="w-full bg-white border border-gray-200/80 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] focus:outline-hidden focus:border-brand-blue transition-all duration-200 cursor-pointer"
            >
              <option value="1" selected>1 Agent</option>
              <option value="2">2 Agents</option>
              <option value="3">3 Agents</option>
              <option value="4">4 Agents</option>
              <option value="custom">Custom / High Scale Scale-up</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label for="contact-shift" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
              Shift Structure <span class="text-[#FF6B4A]">*</span>
            </label>
            <select 
              id="contact-shift" name="shift_structure" required
              class="w-full bg-white border border-gray-200/80 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] focus:outline-hidden focus:border-brand-blue transition-all duration-200 cursor-pointer"
            >
              <option value="full-time" selected>Full Time (40 hrs / week)</option>
              <option value="part-time">Part Time (20 hrs / week)</option>
              <option value="custom-hours">Custom Shift Framework</option>
            </select>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="contact-timezone" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
            Your Target Timezone <span class="text-[#FF6B4A]">*</span>
          </label>
          <div class="relative">
            <select 
              id="contact-timezone" name="timezone" required
              class="w-full bg-white border border-gray-200/80 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] focus:outline-hidden focus:border-brand-blue transition-all duration-200 cursor-pointer appearance-none"
            >
            </select>
            <span id="detected-tz-badge" class="absolute right-3 top-1/2 -translate-y-1/2 bg-brand-green/10 text-brand-green text-[10px] font-black uppercase tracking-wider px-2 py-1 rounded-sm pointer-events-none badge-glow">
              Detected
            </span>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="contact-comments" class="text-xs md:text-md font-black tracking-wide uppercase text-[#3d1d0e]">
            Additional Questions or Bottlenecks to Solve
          </label>
          <textarea 
            id="contact-comments" name="additional_comments" rows="3" placeholder="Tell us about your tools or specific schedule needs..."
            class="w-full bg-white border border-gray-200/80 rounded-xl px-4 py-3.5 text-sm font-medium text-[#3d1d0e] placeholder-gray-400 focus:outline-hidden focus:border-brand-blue transition-all duration-200 resize-none focus:scale-[1.01] transform"
          ></textarea>
        </div>

        <button 
          type="submit"
          class="w-full text-center bg-brand-blue text-white font-black px-8 py-4 rounded-xl hover:bg-brand-green transition-all duration-300 shadow-xs uppercase tracking-wider text-xs md:text-md mt-2 cursor-pointer hover:shadow-md transform active:scale-[0.99]"
        >
          Submit Message
        </button>

      </form>
    </div>
  </div>
</section>

<div id="popup-success" class="fixed inset-0 z-50 items-center justify-center p-4 bg-gray-950/40 backdrop-blur-xs flex hidden opacity-0 transition-opacity duration-300">
  <div class="bg-white rounded-3xl max-w-md w-full p-8 text-center shadow-2xl transform scale-95 transition-transform duration-300 flex flex-col items-center gap-4 border border-gray-100">
    <div class="w-16 h-16 bg-brand-green/10 text-brand-green text-3xl rounded-full flex items-center justify-center font-black animate-bounce">
      ✓
    </div>
    <h3 class="text-2xl font-black text-gray-950 tracking-tight">Message Received!</h3>
    <p class="text-gray-500 text-sm font-medium leading-relaxed">
      Your inquiry has been successfully captured. Our operations lead will review your infrastructure requirements and contact you within 24 business hours.
    </p>
    <button type="button" class="close-popup-btn w-full bg-brand-blue text-white font-bold py-3.5 px-4 rounded-xl text-sm hover:bg-brand-green transition-colors duration-200 cursor-pointer mt-2 uppercase tracking-wider">
      Got it, thanks
    </button>
  </div>
</div>

<div id="popup-error" class="fixed inset-0 z-50 items-center justify-center p-4 bg-gray-950/40 backdrop-blur-xs flex hidden opacity-0 transition-opacity duration-300">
  <div class="bg-white rounded-3xl max-w-md w-full p-8 text-center shadow-2xl transform scale-95 transition-transform duration-300 flex flex-col items-center gap-4 border border-gray-100">
    <div class="w-16 h-16 bg-red-50 text-red-500 text-3xl rounded-full flex items-center justify-center font-black">
      ✕
    </div>
    <h3 class="text-2xl font-black text-red-600 tracking-tight">Submission Failed</h3>
    <p id="popup-error-message" class="text-gray-500 text-sm font-medium leading-relaxed">
      An unexpected corporate server error occurred while trying to submit your operational requirements.
    </p>
    <button type="button" class="close-popup-btn w-full bg-red-600 text-white font-bold py-3.5 px-4 rounded-xl text-sm hover:bg-red-700 transition-colors duration-200 cursor-pointer mt-2 uppercase tracking-wider">
      Review and Try Again
    </button>
  </div>
</div>

<style>
  .scroll-reveal {
    opacity: 0;
    transform: translateY(30px);
    will-change: transform, opacity;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.8s ease-out;
  }

  .scroll-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .scroll-reveal-delayed.is-visible {
    transition-delay: 0.15s;
  }

  .badge-glow {
    animation: pulseGlow 2.5s infinite ease-in-out;
  }

  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.2); }
    50% { box-shadow: 0 0 8px 2px rgba(34, 197, 94, 0.4); }
  }

  .native-tab {
    color: #6b7280;
  }
  .native-tab:has(input:checked) {
    color: #3d1d0e;
  }
  
  .grid:has(label:nth-child(1) input:checked) .tab-slider {
    transform: translateX(0);
  }
  .grid:has(label:nth-child(2) input:checked) .tab-slider {
    transform: translateX(100%);
  }

  input, select, textarea {
    will-change: transform, border-color;
  }
</style>

<script>
  async function sendContactData(formData: FormData): Promise<{ success: boolean; error?: string }> {    
    const GOOGLE_APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwz7A_k5I4GDOGuedA_i78D2LxwVwjFS1bwXQbSLNk59DEX4MsFWn-F__tVZejKcGm-Gg/exec';

    try {      
      const response = await fetch(GOOGLE_APPS_SCRIPT_URL, {
        method: 'POST',
        body: formData // Enviamos el FormData directamente, Apps Script lo procesa de forma nativa
      });

      if (!response.ok) {
        throw new Error(`Server Error: ${response.status} ${response.statusText}`);
      }

      const result = await response.json();
      
      if (result.success) {
        return { success: true };
      } else {
        return { success: false, error: result.error || 'Apps Script returned a failed execution status.' };
      }

    } catch (error: any) {
      return { success: false, error: error?.message || 'Network error' };
    }
  }

  /**
   * INTERFACES ANIMADAS PARA POPUPS (OPEN/CLOSE LOGIC)
   */
  function showModal(modalId: string) {
    const modal = document.getElementById(modalId);
    if (!modal) return;
    modal.classList.remove('hidden');
    setTimeout(() => {
      modal.classList.add('opacity-100');
      const container = modal.firstElementChild;
      if (container) container.classList.replace('scale-95', 'scale-100');
    }, 10);
  }

  function hideModal(modal: HTMLElement) {
    modal.classList.remove('opacity-100');
    const container = modal.firstElementChild;
    if (container) container.classList.replace('scale-100', 'scale-95');
    setTimeout(() => {
      modal.classList.add('hidden');
    }, 300);
  }

  function initContactUX() {
    console.log('📦 [UX Init] Inicializando listeners del formulario de contacto...');
    
    const form = document.querySelector('#business-contact-form') as HTMLFormElement;
    if (!form) return;

    const serviceSelect = form.querySelector('#contact-service') as HTMLSelectElement;
    const planWrapper = form.querySelector('#plan-wrapper') as HTMLDivElement;
    const planSelect = form.querySelector('#contact-plan') as HTMLSelectElement;
    const billingRadios = form.querySelectorAll('input[name="billing_cycle"]');
    const industrySelect = form.querySelector('#contact-industry') as HTMLSelectElement;
    const customIndustryWrapper = form.querySelector('#custom-industry-wrapper') as HTMLDivElement;
    const customIndustryInput = form.querySelector('#contact-custom-industry') as HTMLInputElement;
    const tzSelect = form.querySelector('#contact-timezone') as HTMLSelectElement;
    const phoneCountrySelect = form.querySelector('#contact-country-code') as HTMLSelectElement;

    // --- REVEAL ANIMATIONS ---
    const revealElements = document.querySelectorAll('.scroll-reveal');
    const observerOptions = { root: null, threshold: 0.10 };
    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);
    revealElements.forEach(el => revealObserver.observe(el));

    // --- AUTOMATED TIMEZONE & COUNTRY CODE ---
    if (tzSelect && tzSelect.options.length === 0) {
      const timeZones = (Intl as any).supportedValuesOf?.('timeZone') || ['UTC', 'America/New_York', 'America/Caracas', 'Europe/London'];
      const userTz = Intl.DateTimeFormat().resolvedOptions().timeZone;

      timeZones.forEach((tz: string) => {
        const option = document.createElement('option');
        option.value = tz;
        option.textContent = tz.replace(/_/g, ' ');
        if (tz === userTz) option.selected = true;
        tzSelect.appendChild(option);
      });

      if (phoneCountrySelect) {
        const tzLower = userTz.toLowerCase();
        let targetCountryId = "US";
        if (tzLower.includes('caracas') || tzLower.includes('venezuela')) targetCountryId = "VE";
        else if (tzLower.includes('london') || tzLower.includes('europe/london') || tzLower.includes('gb')) targetCountryId = "UK";
        else if (tzLower.includes('sydney') || tzLower.includes('melbourne') || tzLower.includes('australia')) targetCountryId = "AU";
        else if (tzLower.includes('madrid') || tzLower.includes('spain')) targetCountryId = "ES";
        else if (tzLower.includes('mexico')) targetCountryId = "MX";
        else if (tzLower.includes('bogota') || tzLower.includes('colombia')) targetCountryId = "CO";
        else if (tzLower.includes('buenos_aires') || tzLower.includes('argentina')) targetCountryId = "AR";
        else if (tzLower.includes('santiago') || tzLower.includes('chile')) targetCountryId = "CL";
        else if (tzLower.includes('lima') || tzLower.includes('peru')) targetCountryId = "PE";

        const options = Array.from(phoneCountrySelect.options);
        const matchOption = options.find(opt => opt.getAttribute('data-country-id') === targetCountryId);
        if (matchOption) phoneCountrySelect.value = matchOption.value;
      }
    }

    // --- INTERACTIVE LABELS AND VISIBILITY ---
    function updatePlanLabels(cycle: string) {
      Array.from(planSelect.options).forEach((option) => {
        const monthlyLabel = option.getAttribute('data-label-monthly');
        const anualLabel = option.getAttribute('data-label-anual');
        if (monthlyLabel && anualLabel) {
          option.textContent = cycle === 'annually' ? anualLabel : monthlyLabel;
        }
      });
    }

    function togglePlanFields(serviceValue: string) {
      if (serviceValue === 'predictive-dialer') {
        planWrapper.style.setProperty('display', 'flex', 'important');
        planSelect.required = true;
        setTimeout(() => {
          planWrapper.classList.remove('scale-95', 'opacity-0', 'hidden');
          planWrapper.classList.add('scale-100', 'opacity-100');
        }, 50);
      } else {
        planSelect.required = false;
        planWrapper.classList.remove('scale-100', 'opacity-100');
        planWrapper.classList.add('scale-95', 'opacity-0');
        setTimeout(() => { 
          if (serviceSelect.value !== 'predictive-dialer') {
            planWrapper.style.display = 'none';
            planWrapper.classList.add('hidden');
          }
        }, 300);
        planSelect.value = '';
      }
    }

    function toggleIndustryFields(industryValue: string) {
      if (!customIndustryWrapper || !customIndustryInput) return;

      if (industryValue === 'other') {
        customIndustryWrapper.style.setProperty('display', 'flex', 'important');
        customIndustryInput.required = true;
        setTimeout(() => {
          customIndustryWrapper.classList.remove('scale-95', 'opacity-0', 'hidden');
          customIndustryWrapper.classList.add('scale-100', 'opacity-100');
        }, 50);
      } else {
        customIndustryInput.required = false;
        customIndustryWrapper.classList.remove('scale-100', 'opacity-100');
        customIndustryWrapper.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          if (industrySelect.value !== 'other') {
            customIndustryWrapper.style.display = 'none';
            customIndustryWrapper.classList.add('hidden');
          }
        }, 300);
        customIndustryInput.value = '';
      }
    }

    // --- SINCRONIZACIÓN DE PARÁMETROS URL ---
    const urlParams = new URLSearchParams(window.location.search);
    const annualParam = urlParams.get('anual') || urlParams.get('annual');

    if (annualParam === 'Y') {
      const annualRadio = form.querySelector('input[name="billing_cycle"][value="annually"]') as HTMLInputElement;
      if (annualRadio) {
        annualRadio.checked = true;
        updatePlanLabels('annually');
      }
    } else if (annualParam === 'N') {
      const monthlyRadio = form.querySelector('input[name="billing_cycle"][value="monthly"]') as HTMLInputElement;
      if (monthlyRadio) {
        monthlyRadio.checked = true;
        updatePlanLabels('monthly');
      }
    }

    if (serviceSelect) {
      togglePlanFields(serviceSelect.value);
      serviceSelect.addEventListener('change', () => togglePlanFields(serviceSelect.value));
    }

    if (industrySelect) {
      toggleIndustryFields(industrySelect.value);
      industrySelect.addEventListener('change', () => toggleIndustryFields(industrySelect.value));
    }

    const activeRadio = form.querySelector('input[name="billing_cycle"]:checked') as HTMLInputElement;
    if (activeRadio) updatePlanLabels(activeRadio.value);

    billingRadios.forEach((radio) => {
      radio.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        if (target.checked) updatePlanLabels(target.value);
      });
    });

    // --- CLOSE POPUP LISTENERS ---
    const closeButtons = document.querySelectorAll('.close-popup-btn');
    closeButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const parentModal = target.closest('[id^="popup-"]') as HTMLElement;
        if (parentModal) hideModal(parentModal);
      });
    });

    // --- SUBMIT HANDLING WITH MODALS ---
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalBtnText = submitBtn ? submitBtn.textContent : 'Submit Message';

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending Message...';
        submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
      }

      const rawFormData = new FormData(form);
      const result = await sendContactData(rawFormData);

      if (result.success) {
        showModal('popup-success');
        form.reset();
        
        // Reset manual de campos dinámicos
        if (serviceSelect) togglePlanFields(serviceSelect.value);
        if (industrySelect) toggleIndustryFields(industrySelect.value);
      } else {
        const errMessageElement = document.getElementById('popup-error-message');
        if (errMessageElement && result.error) {
          errMessageElement.textContent = `Details: ${result.error}`;
        }
        showModal('popup-error');
      }

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalBtnText;
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    });
  }

  // Soporte SPA de Astro (astro:page-load) e inicialización tradicional
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactUX);
  } else {
    initContactUX();
  }
  document.addEventListener('astro:page-load', initContactUX);
</script>