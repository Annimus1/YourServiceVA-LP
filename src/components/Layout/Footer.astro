---
// Footer.astro - Creado para Astro + Tailwind v4.0 con Datos Dinámicos

const footerSections = [
  {
    title: 'COMPANY',
    links: [
      { name: 'About us', url: '/about' },
      { name: 'Careers', url: '/careers' },
      { name: 'Contact Us', url: '/contact' }
    ]
  },
  {
    title: 'INDUSTRIES',
    links: [
      { name: 'Finance', url: '/industry/finance' },
      { name: 'Healthcare', url: '/industry/healthcare' },
      { name: 'Home improvement', url: '/industry/home-improvement' },
      { name: 'Legal', url: '/industry/legal' },
      { name: 'Real Estate', url: '/industry/real-estate' },
      { name: 'Solar', url: '/industry/solar' },
    ]
  },
  {
    title: 'RESOURCES',
    links: [
      { name: 'Blog', url: '/blog' },
    ]
  }
];

const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-brand-white text-brand-blue border-t border-gray-100 pt-16 pb-8 px-6">
  <div class="mx-auto max-w-7xl">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 pb-12 border-b border-gray-200/60">
      
      <div class="lg:col-span-4 flex flex-col gap-6">
        <a href="/" class="flex items-center transition-transform active:scale-98">
          <img src="/img/Logo.png" alt="Your Service VA Logo" class="h-12 w-auto object-contain" />
        </a>
        <p class="text-gray-600 font-medium text-base leading-relaxed max-w-sm">
          We believe happy teams build great companies. That's why we ensure the virtual assistants we provide are supported, skilled, and ready to help your business succeed.
        </p>
        
        <div class="flex items-center gap-3 mt-2">
          <a href="https://www.facebook.com/profile.php?id=61556250137883" class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-blue text-white hover:bg-brand-green transition-colors" aria-label="Facebook">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/></svg>
          </a>
          <a href="https://www.instagram.com/your_serviceva?igsh=MW4yYmVuZTl6ODluag==" class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-blue text-white hover:bg-brand-green transition-colors" aria-label="Instagram">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zM17.5 6.5h.01"/></svg>
          </a>
          <a href="#" class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-blue text-white hover:bg-brand-green transition-colors" aria-label="LinkedIn">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
        </div>
      </div>

      <div class="lg:col-span-5 grid grid-cols-2 sm:grid-cols-3 gap-8">
        {footerSections.map((section) => (
          <div class="flex flex-col gap-4">
            <h3 class="text-xs font-bold tracking-widest text-brand-green uppercase">
              {section.title}
            </h3>
            <ul class="flex flex-col gap-3 font-medium text-gray-600 text-sm sm:text-base">
              {section.links.map((link) => (
                <li>
                  <a href={link.url} class="hover:text-brand-green transition-colors">
                    {section.title === 'INDUSTRIES' || section.title === 'COMPANY' 
                      ? link.name 
                      : link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm font-medium text-gray-500">
      <div>
        Copyright © {currentYear} <span class="text-brand-blue font-semibold">YourService</span> | All Rights Reserved.
      </div>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="hover:text-brand-green transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-brand-green transition-colors">Terms & Conditions</a>
      </div>
    </div>

  </div>
</footer>