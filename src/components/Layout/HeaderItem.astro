---
const { dropdown } = Astro.props;
const currentUrl = Astro.url.pathname;

type Item = {
  name: string;
  url: string;
};

const isSubItemActive = (itemUrl: string) => {
  return currentUrl.replace(/\/$/, '') === itemUrl.replace(/\/$/, '');
};

const isDropdownActive = dropdown.subItems.some((item: Item) => isSubItemActive(item.url));
---

<div class="relative group py-4">
  <button 
    class:list={[
      "flex items-center gap-1 transition-colors cursor-pointer font-medium text-md lg:text-xl",
      isDropdownActive 
        ? "text-brand-green" // Si está activo, se queda verde de forma permanente
        : "text-brand-blue hover:text-brand-green" // Si no, mantiene su flujo normal
    ]}
  >
    {dropdown.title}
    
    <svg 
      class:list={[
        "h-4 w-4 transition-transform duration-200 group-hover:rotate-180 group-hover:text-brand-green",
        isDropdownActive 
          ? " text-brand-green" // Si está activo, se queda rotado y verde
          : "text-gray-400"
      ]}
      fill="none" 
      viewBox="0 0 24 24" 
      stroke="currentColor" 
      stroke-width="2.5"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  
  <div class="absolute top-full left-0 mt-0 hidden group-hover:flex flex-col min-w-56 rounded-xl bg-white p-2 shadow-xl border border-gray-100/50 animate-in fade-in slide-in-from-top-2 duration-150 z-50">
    {dropdown.subItems.map((item: Item) => {
      const active = isSubItemActive(item.url);
      return (
        <a 
          href={item.url} 
          class:list={[
            "block rounded-lg px-4 py-2.5 text-base transition-colors font-medium",
            active 
              ? "bg-[#FAF8F5] text-brand-green" // Resaltado sutil si es la página exacta en la que está
              : "text-brand-blue hover:bg-[#FAF8F5] hover:text-brand-green"
          ]}
        >
          {item.name}
        </a>
      );
    })}
  </div>
</div>