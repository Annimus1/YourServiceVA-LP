---
import HeaderItem from './HeaderItem.astro'; // Asegúrate de apuntar a la ruta correcta

const dropdowns = [
  {
    title: 'Services',
    subItems: [
      { name: 'Customer Service', url: '/services/customer-service' },
      { name: 'Human Resources', url: '/services/human-resources' },
      { name: 'Inside Sales Agent', url: '/services/inside-sales-agent' },
      { name: 'Intake Specialist', url: '/services/intake' },
      { name: 'Lead Generation', url: '/services/lead-generation' },
      { name: 'Predictive Dialer', url: '/services/predictive-dialer-software' },
      { name: 'Tech Support', url: '/services/tech-support' },
      { name: 'Virtual Assistants', url: '/services/virtual-assistants' },
    ]
  },
  {
    title: 'Industries',
    subItems: [
      { name: 'Finance', url: '/industry/finance' },
      { name: 'Healthcare', url: '/industry/healthcare' },
      { name: 'Home Improvement', url: '/industry/home-improvement' },
      { name: 'Legal', url: '/industry/legal' },
      { name: 'Real Estate', url: '/industry/real-estate' },
      { name: 'Solar', url: '/industry/solar' },

    ]
  },
  {
    title: 'Resources',
    subItems: [
      { name: 'Blog', url: '/blog' },
    ]
  },
];

const simpleLinks = [
  { name: 'Pricing', url: '#pricing' },
  { name: 'About', url: '#about' },
  { name: 'Careers', url: '#careers' },
  { name: 'Contact', url: '#contact' }
];
---

<header class="sticky top-0 z-50 w-full bg-[#FAF8F5] border-b border-gray-100 px-6">
  <div class="mx-auto flex max-w-7xl items-center justify-between">
    
    <a href="/" class="flex items-center group transition-transform active:scale-98 py-4">
      <img src="/img/Logo.png" alt="Your Service VA Logo" class="h-16 md:h-20 w-auto object-contain" />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {dropdowns.map((dropdown) => (
        <HeaderItem dropdown={dropdown} />
      ))}

      {simpleLinks.map((link) => (
        <a href={link.url} class="text-brand-blue font-medium text-md lg:text-xl hover:text-brand-green transition-colors py-4">{link.name}</a>
      ))}
    </nav>

    <div class="flex items-center gap-4 py-4">
      <a href="#" class="hidden sm:inline-flex items-center justify-center rounded-xl bg-brand-blue px-6 py-3 text-sm font-semibold text-white shadow-md hover:bg-brand-green/90 transition-all cursor-pointer active:scale-98">
        Get Started
      </a>

      <button id="mobile-menu-button" class="md:hidden flex h-10 w-10 items-center justify-center rounded-lg text-brand-blue hover:bg-gray-100 transition-colors cursor-pointer" aria-label="Toggle Menu">
        <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-[#FAF8F5] border-b border-gray-200 px-6 py-6 shadow-lg max-h-[calc(100vh-80px)] overflow-y-auto">
    <nav class="flex flex-col gap-2 font-medium text-brand-blue">
      
      {dropdowns.map((dropdown) => (
        <div class="mobile-dropdown-container">
          <button class="w-full flex items-center justify-between py-3 border-b border-gray-100/80 hover:text-brand-green cursor-pointer">
            <span>{dropdown.title}</span>
            <svg class="h-4 w-4 text-gray-400 transition-transform duration-200 mobile-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div class="hidden flex-col bg-gray-50/60 rounded-xl mt-1 px-4 py-2 gap-1 mobile-sub-menu">
            {dropdown.subItems.map((item) => (
              <a href={item.url} class="block py-2 text-sm text-gray-700 hover:text-brand-green font-medium">
                {item.name}
              </a>
            ))}
          </div>
        </div>
      ))}

      {simpleLinks.map((link) => (
        <a href={link.url} class="py-3 border-b border-gray-100/80 hover:text-brand-green">{link.name}</a>
      ))}
      
      <a href="#" class="sm:hidden mt-4 w-full inline-flex items-center justify-center rounded-xl bg-brand-blue py-3 text-sm font-semibold text-white shadow-sm">
        Get Started
      </a>
    </nav>
  </div>
</header>

<script>
  function setupNavbar() {
    // Menú Móvil Hamburguesa
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    mobileMenuButton?.addEventListener('click', () => {
      const isHidden = mobileMenu?.classList.toggle('hidden');
      hamburgerIcon?.classList.toggle('hidden', !isHidden);
      closeIcon?.classList.toggle('hidden', isHidden);
    });

    // Dropdowns Móviles (Mantienen click para usabilidad móvil)
    const mobileDropdowns = document.querySelectorAll('.mobile-dropdown-container');
    mobileDropdowns.forEach(container => {
      const button = container.querySelector('button');
      const subMenu = container.querySelector('.mobile-sub-menu');
      const arrow = container.querySelector('.mobile-arrow');

      button?.addEventListener('click', () => {
        const isHidden = subMenu?.classList.toggle('hidden');
        subMenu?.classList.toggle('flex', !isHidden);
        arrow?.classList.toggle('rotate-180', !isHidden);
      });
    });
  }

  setupNavbar();
  document.addEventListener('astro:page-load', setupNavbar);
</script>