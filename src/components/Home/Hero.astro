---
---

<section class="relative w-full bg-[#FAF8F5] overflow-hidden px-6 py-12 md:py-20 lg:py-28">
  <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    
    <div class="lg:col-span-7 flex flex-col gap-6 md:gap-8 order-2 lg:order-1 text-left">
      
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-[#3d1d0e] tracking-tight leading-tight">
        Hire Top Virtual <br class="hidden sm:inline"/> Assistants
      </h1>

      <ul class="flex flex-col gap-4 text-base sm:text-lg font-medium text-gray-700">
        <li class="flex items-start gap-3">
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-green text-white text-xs font-bold mt-0.5">
            ✓
          </span>
          <span>Experienced, trained & college educated virtual assistants.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-green text-white text-xs font-bold mt-0.5">
            ✓
          </span>
          <span>Free up your time — stop drowning in menial tasks.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-green text-white text-xs font-bold mt-0.5">
            ✓
          </span>
          <span>Get more done — while maintaining low overhead cost starting at $7.99/hr</span>
        </li>
      </ul>

      <div class="inline-flex items-center">
        <span class="text-lg md:text-xl font-bold text-brand-blue bg-brand-blue/5 px-4 py-2 rounded-lg border border-brand-blue/10">
          🎁 Get $100 Off Your First Month
        </span>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4 mt-2">
        <a href="#contact" class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-brand-blue px-8 py-4 text-base font-bold text-white shadow-lg hover:bg-brand-blue/90 transition-all transform active:scale-98 cursor-pointer">
          Get Your Virtual Assistant
        </a>
        <a href="#pricing" class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-white border-2 border-gray-200 px-8 py-4 text-base font-bold text-brand-blue hover:bg-gray-50 hover:border-gray-300 transition-colors cursor-pointer">
          Pricing
        </a>
      </div>

      <div class="flex flex-wrap items-center gap-6 pt-6 border-t border-gray-200/60 mt-4">
        <div class="flex -space-x-3 overflow-hidden">
          <img class="inline-block h-10 w-10 rounded-full ring-2 ring-[#FAF8F5] object-cover" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&q=80&w=100" alt="User 1" />
          <img class="inline-block h-10 w-10 rounded-full ring-2 ring-[#FAF8F5] object-cover" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=100" alt="User 2" />
          <img class="inline-block h-10 w-10 rounded-full ring-2 ring-[#FAF8F5] object-cover" src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&q=80&w=100" alt="User 3" />
        </div>
        
        <div class="flex flex-col gap-0.5">
          <div class="flex items-center gap-1 text-amber-500 text-lg">
            ★ ★ ★ ★ ★
          </div>
          <p class="text-xs font-bold text-gray-500">4.9 (454 reviews)</p>
        </div>

        <div class="hidden sm:block h-8 w-px bg-gray-200"></div>

        <div class="flex items-center gap-4 text-gray-400 font-bold tracking-tight text-sm">
          <span class="text-gray-500">REVIEWED ON</span>
          <span class="text-emerald-600 flex items-center gap-1 font-extrabold text-base">
            <span class="text-xl">★</span> Trustpilot
          </span>
          <span class="text-slate-800 font-black text-base tracking-tighter">Clutch</span>
        </div>
      </div>

    </div>

    <div class="lg:col-span-5 order-1 lg:order-2 flex justify-center relative w-full min-h-85 sm:min-h-110 md:min-h-125">
      
      <div class="relative w-full max-w-md lg:max-w-none flex items-end justify-center">
        <img 
          src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=600" 
          alt="Top Virtual Assistant Professional" 
          class="w-4/5 sm:w-auto h-80 sm:h-105 md:h-120 lg:h-130 object-contain object-bottom z-10 filter drop-shadow-xl"
        />

        <div class="hidden absolute top-8 right-0 sm:right-4 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 md:flex flex-col gap-2 min-w-40 sm:min-w-47.5 animate-bounce-slow">
          <div class="flex items-center justify-between text-xs font-bold text-gray-400">
            <span>To-do</span>
            <span class="h-5 w-5 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center">1</span>
          </div>
          <label class="flex items-center gap-2 text-[11px] sm:text-xs font-medium text-gray-400 line-through decoration-gray-300">
            <input type="checkbox" checked disabled class="rounded text-purple-600 focus:ring-0 h-3.5 w-3.5" />
            Client Call - 2:00 PM
          </label>
          <label class="flex items-center gap-2 text-[11px] sm:text-xs font-semibold text-gray-700">
            <input type="checkbox" checked disabled class="rounded text-emerald-500 focus:ring-0 h-3.5 w-3.5" />
            Follow-Up Emails - 4:00 PM
          </label>
        </div>

        <div class="hidden absolute bottom-24 -left-2 sm:left-0 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 max-w-50 sm:max-w-60 md:flex flex-col gap-2">
          <div class="flex items-center gap-2 border-b border-gray-100 pb-1.5">
            <div class="h-6 w-6 rounded-full bg-sky-200 text-[10px] font-bold flex items-center justify-center">GN</div>
            <div class="flex flex-col">
              <span class="text-[11px] font-bold text-gray-800 leading-none">George Nielsen</span>
              <span class="text-[9px] text-gray-400">President of Sales</span>
            </div>
          </div>
          <p class="text-[10px] sm:text-[11px] font-medium text-gray-600 bg-gray-50 rounded-lg p-2">
            Hi! Thanks for reaching out. How can I assist you today?
          </p>
          <p class="text-[10px] sm:text-[11px] font-semibold text-white bg-brand-blue rounded-lg p-2 self-end text-right">
            Hi! can you help book a new reservation under my account?
          </p>
        </div>

        <div class="absolute bottom-6 right-0 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 flex flex-col gap-2 min-w-37.5 sm:min-w-45">
          <div class="flex items-center gap-1.5 text-xs font-bold text-gray-800">
            <span class="text-brand-blue">📬</span> Email Inbox <span class="text-brand-green font-extrabold">(2)</span>
          </div>
          <div class="flex flex-col gap-1 text-[10px] font-medium text-gray-500">
            <div class="p-1.5 bg-gray-50 rounded border-l-2 border-brand-green text-gray-700 font-semibold">Stay connected with team</div>
            <div class="p-1.5 bg-gray-50 rounded border-l-2 border-brand-blue">When the huddle is over</div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  /* Animación sutil para el widget de To-Do */
  .animate-bounce-slow {
    animation: softBounce 4s infinite ease-in-out;
  }
  @keyframes softBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
</style>