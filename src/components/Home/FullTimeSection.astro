<section class="w-full bg-[#FFF] py-16 md:py-24 px-6 overflow-hidden border-b border-gray-100">
  <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    
    <div class="lg:col-span-6 flex flex-col gap-6 scroll-animate-left">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-[#3d1d0e] tracking-tight leading-tight">
        Full-Time Admin, Sales, & Support Virtual Assistants
      </h2>
      
      <p class="text-gray-600 font-medium text-base sm:text-lg leading-relaxed max-w-xl">
        YourService’s virtual assistant outsourcing provides 24/7, multilingual support to handle the daily tasks in your organization. From calendar management and inbox support to customer chat and CRM entry, our virtual assistants handle it all.
      </p>

      <div class="h-1 w-20 bg-brand-green rounded-full mt-2"></div>
    </div>

    <div class="lg:col-span-6 flex justify-center lg:justify-end scroll-animate-right">
      <div class="relative w-full max-w-md lg:max-w-none aspect-4/3 sm:aspect-video lg:aspect-square rounded-3xl overflow-hidden shadow-2xl border border-white/20 group">
        
        <img 
          src="https://images.unsplash.com/photo-1507679799987-c73779587ccf?auto=format&fit=crop&q=80&w=800" 
          alt="Professional working on laptop outdoor" 
          class="w-full h-full object-cover object-center transform group-hover:scale-105 transition-transform duration-700 ease-out"
        />

        <div class="absolute inset-0 bg-linear-to-t from-[#3d1d0e]/10 to-transparent pointer-events-none"></div>
      </div>
    </div>

  </div>
</section>

<style>
  /* ==========================================================================
     ANIMACIONES POR SCROLL (Scroll-Driven Animations Nativo)
     ========================================================================== */
  
  @keyframes revealUp {
    from {
      opacity: 0;
      transform: translateY(50px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes revealIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(30px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* Soporte moderno para navegadores que ya implementan animation-timeline */
  @supports (animation-timeline: view()) {
    .scroll-animate-left {
      animation: revealUp linear both;
      animation-timeline: view();
      animation-range: entry 10% cover 40%;
    }

    .scroll-animate-right {
      animation: revealIn linear both;
      animation-timeline: view();
      animation-range: entry 15% cover 45%;
    }
  }

  /* Fallback clásico mediante transiciones suaves si el navegador no soporta scroll-driven */
  @not supports (animation-timeline: view()) {
    .scroll-animate-left, .scroll-animate-right {
      opacity: 1;
      transform: none;
    }
  }
</style>