---
import Image from 'astro/components/Image.astro';
import image1 from '../../assets/image1.webp';
import image2 from '../../assets/image2.webp';
import image3 from '../../assets/image3.webp';
import image4 from '../../assets/image4.webp';
import image5 from '../../assets/image5.webp';
---

<section class="w-full bg-brand-blue py-20 md:py-28 px-6 overflow-hidden relative">
  <div class="absolute top-1/4 left-1/3 text-white/10 text-3xl font-light select-none pointer-events-none float-slow">▲</div>
  <div class="absolute bottom-1/4 right-1/3 text-white/10 text-4xl font-light select-none pointer-events-none float-delayed">⬠</div>

  <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center relative z-10">
    
    <div class="lg:col-span-5 flex flex-col items-start gap-6 text-white">
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight">
        We Invest in <br />
        <span class="text-brand-green">People</span>
      </h2>
      
      <p class="text-white/90 text-base md:text-lg leading-relaxed font-medium">
        At Your Service, we believe that great teams build great companies. We prioritize the growth and well-being of every member of our team. Our talented assistants are supported, appreciated, and empowered to help your business succeed, which shows through our industry-leading retention and performance.
      </p>

      <a 
        href="/culture" 
        class="inline-flex items-center justify-center px-8 py-3.5 bg-white text-brand-blue font-bold rounded-xl shadow-md hover:bg-brand-green hover:text-white transition-all duration-300 transform hover:-translate-y-0.5 mt-2"
      >
        Our Culture
      </a>
    </div>

    <div class="lg:col-span-7 flex justify-center items-center min-h-112.5 md:min-h-137.5 relative w-full mt-8 lg:mt-0">
      
      <div class="relative w-full max-w-125 h-100">
        
        <div class="absolute bottom-0 left-0 w-48 h-48 md:w-56 md:h-56 rounded-full border-4 border-white overflow-hidden shadow-2xl z-30 float-slow">
          <Image 
            src={image1} 
            alt="Team member" 
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <div class="absolute bottom-4 right-4 w-36 h-36 md:w-44 md:h-44 rounded-full border-4 border-[#8ec63f] overflow-hidden shadow-2xl z-20 float-delayed">
          <Image 
            src={image2} 
            alt="Support specialist" 
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <div class="absolute top-12 left-1/2 -translate-x-1/2 w-32 h-32 md:w-36 md:h-36 rounded-full border-4 border-white/80 overflow-hidden shadow-xl z-20 float-slow">
          <Image 
            src={image3} 
            alt="Customer success agent" 
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <div class="absolute top-0 right-12 w-28 h-28 md:w-32 md:h-32 rounded-full border-4 border-white/60 overflow-hidden shadow-lg z-10 float-delayed">
          <Image
            src={image4} 
            alt="Virtual assistant executive" 
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <div class="absolute top-16 left-4 w-20 h-20 md:w-24 md:h-24 rounded-full border-2 border-white/40 overflow-hidden shadow-md z-10 float-slow">
          <Image 
            src={image5}
            alt="Remote specialist" 
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  /* ==========================================================================
     ANIMACIONES DE EFECTO FLOTANTE (Eje X, Y + Rotación sutil)
     ========================================================================== */

  @keyframes floatAnimationOne {
    0% {
      transform: translateY(0px) translateX(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-12px) translateX(6px) rotate(1.5deg);
    }
    100% {
      transform: translateY(0px) translateX(0px) rotate(0deg);
    }
  }

  @keyframes floatAnimationTwo {
    0% {
      transform: translateY(0px) translateX(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-8px) translateX(-8px) rotate(-1deg);
    }
    100% {
      transform: translateY(0px) translateX(0px) rotate(0deg);
    }
  }

  .float-slow {
    animation: floatAnimationOne 6s ease-in-out infinite;
  }

  .float-delayed {
    animation: floatAnimationTwo 7s ease-in-out infinite;
    animation-delay: 1s; /* Desfase para que no se muevan todas al unísono */
  }

  /* Optimización para usuarios que prefieren no ver animaciones */
  @media (prefers-reduced-motion: reduce) {
    .float-slow, .float-delayed {
      animation: none !important;
    }
  }
</style>