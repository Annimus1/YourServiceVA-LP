---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Common/Hero.astro";
import TrustedBy from "../components/Common/TrustedBy.astro";
import GenericSection from "../components/Common/GenericSection.astro";
import RolesTasks from "../components/Home/RolesTasks.astro";
import HowItWorks from "../components/Common/HowItWorks.astro";
import ClientReviews from "../components/Common/ClientReviews.astro";
import WeInvestInPeople from "../components/Home/WeInvestInPeople.astro";
import FAQ from "../components/Common/FAQ.astro";


const heroData = {
  titleA: "Hire Top Virtual",
  titleB: "Assistants",
  btn: {
    text: "Get Your Virtual Assistant",
    link: "#contact"
  },
  items : [
    "Experienced, trained & college educated virtual assistants.", 
    "Free up your time — stop drowning in menial tasks.", 
    "Get more done — while maintaining low overhead cost starting at $7.99/hr"],
  photo: "https://plus.unsplash.com/premium_photo-1661778889409-2cc359d88e31?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"

}

const FullTimeSectionData = {
  title: "Full-Time Admin, Sales, & Support Virtual Assistants",
  description: "YourService’s virtual assistant outsourcing provides 24/7, multilingual support to handle the daily tasks in your organization. From calendar management and inbox support to customer chat and CRM entry, our virtual assistants handle it all.",
  image: "https://images.unsplash.com/photo-1589386417686-0d34b5903d23?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  flow: "normal"
}

const FAQs = {
  title: "Virtual Assistant Outsourcing",
  description:"From virtual assistants and customer support to sales, marketing, bookkeeping, and tech.",
  questions: [
    {
    question: "What types of tasks can your VAs handle?",
    answer: "Our virtual assistants are highly trained to manage administrative duties, customer support, data entry, CRM updates, calendar management, email optimization, social media scheduling, and specialized technical or sales workflows tailored to your operational requirements."
  },
  {
    question: "How fast can I get started?",
    answer: "The onboarding workflow is built for swift integration. Once we match your operational needs with our ideal agents, standard setup and strategic kickoff transitions can be fully finalized within 24 to 48 hours."
  },
  {
    question: "Are your VAs dedicated or shared?",
    answer: "We offer dedicated solutions. Your assigned assistant integrates directly into your business, aligning seamlessly with your daily operational procedures, company culture, and communication channels."
  },
  {
    question: "Can I scale hours up or down later?",
    answer: "Absolutely. Our solutions are highly adaptable, letting you expand or downscale active task allocations as your dynamic quarterly targets or business scale requirements change."
  },
  {
    question: "How do I communicate my VA's work?",
    answer: "You maintain total collaborative oversight through your preferred channels, whether utilizing Slack, Microsoft Teams, Zoom, email, or your internal project management boards."
  },
  {
    question: "How can I track my VA's performance and time?",
    answer: "Every single task is documented via industry-standard time-tracking software. You receive comprehensive, transparent performance summaries mapping out every logged minute and completed deliverable."
  }
  ]
}
---

<Layout   title="YourServiceva">
  <Hero  heroData={heroData}>
    <div class="hidden absolute top-8 right-0 sm:right-4 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 md:flex flex-col gap-2 min-w-40 sm:min-w-47.5 animate-bounce-slow">
      <div class="flex items-center justify-between text-xs font-bold text-gray-400">
        <span>To-do</span>
        <span class="h-5 w-5 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center">1</span>
      </div>
      <label class="flex items-center gap-2 text-[11px] sm:text-xs font-medium text-gray-400 line-through decoration-gray-300">
        <input type="checkbox" checked disabled class="rounded text-purple-600 focus:ring-0 h-3.5 w-3.5" />
          Client Call - 2:00 PM
        </label>
      <label class="flex items-center gap-2 text-[11px] sm:text-xs font-semibold text-gray-700">
      <input type="checkbox" checked disabled class="rounded text-emerald-500 focus:ring-0 h-3.5 w-3.5" />
        Follow-Up Emails - 4:00 PM
      </label>
    </div>

    <div class="hidden absolute bottom-24 -left-2 sm:left-0 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 max-w-50 sm:max-w-60 md:flex flex-col gap-2">
      <div class="flex items-center gap-2 border-b border-gray-100 pb-1.5">
        <div class="h-6 w-6 rounded-full bg-sky-200 text-[10px] font-bold flex items-center justify-center">GN</div>
        <div class="flex flex-col">
          <span class="text-[11px] font-bold text-gray-800 leading-none">George Nielsen</span>
          <span class="text-[9px] text-gray-400">President of Sales</span>
        </div>
      </div>
      <p class="text-[10px] sm:text-[11px] font-medium text-gray-600 bg-gray-50 rounded-lg p-2">
        Hi! Thanks for reaching out. How can I assist you today?
      </p>
      <p class="text-[10px] sm:text-[11px] font-semibold text-white bg-brand-blue rounded-lg p-2 self-end text-right">
        Hi! can you help book a new reservation under my account?
      </p>
    </div>

    <div class="absolute bottom-6 right-0 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 flex flex-col gap-2 min-w-37.5 sm:min-w-45">
      <div class="flex items-center gap-1.5 text-xs font-bold text-gray-800">
        <span class="text-brand-blue">📬</span> Email Inbox <span class="text-brand-green font-extrabold">(2)</span>
      </div>
      <div class="flex flex-col gap-1 text-[10px] font-medium text-gray-500">
        <div class="p-1.5 bg-gray-50 rounded border-l-2 border-brand-green text-gray-700 font-semibold">Stay connected with team</div>
        <div class="p-1.5 bg-gray-50 rounded border-l-2 border-brand-blue">When the huddle is over</div>
      </div>
    </div>
  </Hero>
  <TrustedBy />
  <GenericSection genericData={FullTimeSectionData} />
  <RolesTasks />
  <FAQ FAQs={FAQs} />
  <HowItWorks />
  <ClientReviews />
  <WeInvestInPeople />
</Layout>
