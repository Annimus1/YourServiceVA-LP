---
// src/pages/contact.astro
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/Contact/ContactForm.astro";
import ClientReviews from "../components/Common/ClientReviews.astro";
---

<Layout title="Contact Our Operational Team | Remote Operations & Dialer Infrastructure">
  <main class="w-full min-h-screen bg-white">
    
    <section class="w-full min-h-[80vh] bg-brand-dark-blue text-white pt-24 pb-12 px-6 md:px-12 relative overflow-hidden flex flex-col justify-between items-center">
      
      <div class="absolute inset-0 opacity-5 pointer-events-none mix-blend-overlay">
        <div class="absolute top-[-10%] left-[-10%] w-[600px] h-[600px] rounded-full bg-brand-blue filter blur-3xl"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[600px] h-[600px] rounded-full bg-brand-green filter blur-3xl"></div>
      </div>

      <div class="max-w-7xl mx-auto my-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10 text-left">
        
        <div class="lg:col-span-7 flex flex-col gap-4 animate-fade-in">
          <span class="w-fit text-brand-green font-black uppercase tracking-widest text-xs bg-brand-green/10 px-3 py-1.5 rounded-md border border-brand-green/20">
            Scale Your Team Securely
          </span>
          
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-black tracking-tight leading-tight">
            Let’s Align Your <br /> Remote Operations
          </h1>
          
          <p class="text-gray-300 text-sm sm:text-base md:text-lg font-medium max-w-xl leading-relaxed mt-2">
            From dialer architecture setup to managed talent sourcing, tell us about your infrastructure bottlenecks. Our core operational leads will evaluate your case.
          </p>
        </div>

        <div class="lg:col-span-5 flex justify-center items-center animate-fade-in-delayed">
          <div class="relative w-full max-w-md aspect-square rounded-2xl p-4 backdrop-blur-xs shadow-2xl overflow-hidden group">
            <img 
              src="https://images.unsplash.com/photo-1578357078586-491adf1aa5ba?q=80&w=764&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
              alt="Remote Operations Infrastructure" 
              class="w-full h-full object-cover rounded-xl opacity-90 group-hover:scale-105 transition-transform duration-500 ease-out"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
          </div>
        </div>

      </div>

      <div class="w-full flex justify-center pb-4 mt-10 relative z-10">
        <a href="#contact-section" class="flex flex-col items-center gap-2 text-gray-400 text-[11px] font-black uppercase tracking-widest hover:text-brand-green transition-colors duration-200 animate-bounce cursor-pointer">
          <span>Configure setup below</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-4 h-4 text-brand-green">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </a>
      </div>
      
    </section>

    <ContactForm />
    
    <section class="border-t border-gray-100 bg-[#FAF8F5]/30">
      <ClientReviews />
    </section>

  </main>
</Layout>

<style>
  /* Animaciones de entrada escalonadas */
  .animate-fade-in {
    opacity: 0;
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .animate-fade-in-delayed {
    opacity: 0;
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Forzar un bounce un poco más suave y marcado */
  .animate-bounce {
    animation: softBounce 2s infinite;
  }

  @keyframes softBounce {
    0%, 100% {
      transform: translateY(0);
      animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
    }
    50% {
      transform: translateY(8px);
      animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
    }
  }
</style>