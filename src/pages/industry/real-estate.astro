---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Common/Hero.astro';
import TrustedBy from '../../components/Common/TrustedBy.astro';
import GenericSection from '../../components/Common/GenericSection.astro';
import HowItWorks from '../../components/Common/HowItWorks.astro';
import ClientReview from '../../components/Common/ClientReviews.astro';
import FAQ from '../../components/Common/FAQ.astro';
import RolesSupported from '../../components/Common/RolesSupported.astro';

const heroData = {
  titleA: "Real Estate Virtual",
  titleB: "Assistants",
  items: ["Our trained real estate virtual assistants help agents, brokers, investors, and property managers stay organized and on top of daily operations, handling everything from listing and transaction management to bookkeeping and lead generation."],
  btn: {
    text: "Build Your Real Estate Team",
    link: "/pricing"
  },
  photo: "https://cdn.prod.website-files.com/6880b79a825dc00d03bc2ee6/68b2cb8ee38be7701eabfc6a_medium-shot-man-working-as-real-estate-agent-p-1080.webp",
}
const reOperations = {
  title: "Outsource Real Estate Operations to Increase Revenue and Improve Service",
  description: "YourServiceva can take over your admin, marketing, and transaction management, helping you focus on improving sales and servicing clients. Our services are designed for all real estate professionals, including solo agents and brokerages.",
  image: "https://cdn.prod.website-files.com/6880b79a825dc00d03bc2ee6/68b28dd187e457b5e3ba3aba_Frame%202131335248%20(6).webp",
  flow: "normal"
}
const rolesSupported = {
  title: "Real Estate Virtual Assistant Roles We Support",
  description: "Our real estate virtual assistant services infuse industry-leading tools and best practices into your workflows. Here are some of the services we offer: ",
  items: [
  {
    title: "Prospecting & cold calling lead pipelines", //
    description: "Identify high-potential leads, execute outbound calling strategies, and consistently fill your sales pipeline.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.635-5.165-3.976-6.8-6.8l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.75Z" /></svg>`
  },
  {
    title: "Appointment setting & calendar coordination", //
    description: "Manage your daily agenda, schedule client consultations, and synchronize calendars to prevent double-bookings.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>`
  },
  {
    title: "MLS listings: creation, updates, photo uploads", //
    description: "Draft comprehensive property sheets, optimize layouts, upload high-res imagery, and keep public inventory data flawless.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>`
  },
  {
    title: "Transaction coordination: contracts, disclosures, compliance forms", //
    description: "Oversee the closing process by ensuring disclosures, deal compliance files, and agreements remain structurally complete.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0-4.5 4.5M21 7.5H7.5" /></svg>`
  },
  {
    title: "CRM management & database upkeep", //
    description: "Keep contact logs structured, tag prospective buyers accurately, and clean up inactive profiles in real-time.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" /></svg>`
  },
  {
    title: "Contract management & document filing", //
    description: "Organize signature executions via digital tools, maintain neat cloud storage structures, and verify audit-ready data archiving.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12" /></svg>`
  },
  {
    title: "Bookkeeping, invoicing & financial reporting", //
    description: "Track incoming escrow balances, process vendor invoicing, log brokerage expenses, and prepare profit sheets.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5Z" /></svg>`
  },
  {
    title: "Property management tasks: rent reminders, maintenance ticketing", //
    description: "Liaise between tenants and contractors, issue timely rent notifications, and track reactive repairs until completion.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.83-5.83m0 0a2.999 2.999 0 0 0-4.142-4.142m4.142 4.142-1.729 1.73m0 0L3 18.25V21h2.75l7.53-7.53m-2.75-2.75-1.73 1.73m0 0-4.78 4.78m11.53-11.53a2.999 2.999 0 0 0-4.142-4.142l-1.729 1.73m0 0 1.73 1.73" /></svg>`
