}

const FAQs = {
  title: "Real Estate Virtual Assistant",
  description: "From virtual assistants and customer support to sales, marketing, bookkeeping, and tech.",
  questions: [
  {
    question: "What real estate tasks can I outsource?", //
    answer: "You can outsource a wide range of administrative, operational, and marketing tasks. This includes cold calling and lead generation, appointment setting, MLS listings updates, CRM database upkeep, bookkeeping, transaction coordination, and social media management."
  },
  {
    question: "Can YourServiceva assist with transactions and contract filing?", //
    answer: "Yes, our specialized real estate virtual assistants can handle end-to-end transaction coordination. They manage contracts, compile disclosures, ensure form compliance, and handle digital document archiving to keep your deals organized and audit-ready."
  },
  {
    question: "Are your assistants trained in MLS and CRM systems?", //
    answer: "Absolutely. Our real estate virtual assistants come experienced and trained in industry-standard tools. They efficiently manage MLS property sheets, photo uploads, and maintain high-performing CRM platforms to keep your workflows seamless."
  },
  {
    question: "Do you handle property management tasks like rent reminders, and maintenance follow-ups?", //
    answer: "Yes, we support property management workflows. Our virtual assistants can send timely rent reminders to tenants, log incoming maintenance tickets, coordinate with local contractors, and track repair tasks until completion."
  },
  {
    question: "How quickly can I get started, and what are the costs?", //
    answer: "Getting started is quick and straightforward. After an initial consultation to review your business needs, we match you with a trained specialist within a few days. Our pricing plans are flexible and tailored to the level of support and hours your agency requires."
  }
]}
---

<Layout title="Real Estate Industry" description="Explore the latest trends and insights in the real estate industry.">
  <Hero heroData={heroData}>
    <div class="absolute top-[45%] md:top-[15%] -left-2 md:-left-6 sm:-left-12 z-20 bg-white/95 backdrop-blur-xs rounded-2xl p-4 shadow-xl border border-gray-100 flex flex-col gap-3 max-w-45 sm:max-w-52.5 animate-bounce-slow">
    <div class="flex items-center gap-2">
      <span class="text-brand-green text-lg">📊</span>
      <h4 class="font-extrabold text-[#3d1d0e] text-sm sm:text-base tracking-tight">Property Listing</h4>
    </div>
    
    <div class="flex flex-col gap-2">
      <label class="flex items-center gap-2 bg-[#FAF8F5] px-3 py-2 rounded-xl border border-gray-100/80 cursor-pointer">
        <input type="checkbox" checked class="accent-brand-green h-4 w-4 rounded-sm" disabled />
        <span class="text-xs font-bold text-gray-600">Duplex Villa</span>
      </label>
      <label class="flex items-center gap-2 bg-[#FAF8F5] px-3 py-2 rounded-xl border border-gray-100/80 cursor-pointer">
        <input type="checkbox" checked class="accent-brand-green h-4 w-4 rounded-sm" disabled />
        <span class="text-xs font-bold text-gray-600">Modern Condo</span>
      </label>
    </div>
  </div>

  <div class="hidden absolute top-[5%] -right-6 sm:-right-16 z-20 bg-white/95 backdrop-blur-xs rounded-2xl p-4 shadow-xl border border-gray-100 md:flex flex-col gap-3 min-w-50 sm:min-w-60">
    <h4 class="font-extrabold text-[#3d1d0e] text-xs sm:text-sm tracking-tight border-b border-gray-50 pb-2">Recent Transaction</h4>
    
    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <div class="h-8 w-8 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center font-bold text-xs">💳</div>
          <div class="flex flex-col">
            <span class="text-xs font-bold text-[#3d1d0e]">Deposit from my Card</span>
            <span class="text-[10px] text-gray-400 font-medium">28 January 2026</span>
          </div>
        </div>
        <span class="text-xs font-black text-red-500">-$850</span>
      </div>

      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <div class="h-8 w-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs">P</div>
          <div class="flex flex-col">
            <span class="text-xs font-bold text-[#3d1d0e]">Deposit Paypal</span>
            <span class="text-[10px] text-gray-400 font-medium">28 January 2026</span>
          </div>
        </div>
        <span class="text-xs font-black text-emerald-500">+$2,500</span>
      </div>

      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <div class="h-8 w-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center font-bold text-xs">👤</div>
          <div class="flex flex-col">
            <span class="text-xs font-bold text-[#3d1d0e]">Jemi Wilson</span>
            <span class="text-[10px] text-gray-400 font-medium">28 January 2026</span>
          </div>
        </div>
        <span class="text-xs font-black text-emerald-500">+$5,400</span>
      </div>
    </div>
  </div>

  <div class="absolute bottom-[55%] md:bottom-[20%] -right-3 md:-right-8 sm:-right-12 z-20 bg-white/95 backdrop-blur-xs rounded-2xl p-4 shadow-xl border border-gray-100 flex flex-col gap-2 max-w-[160px] sm:max-w-[190px] [animation-delay:2s] animate-bounce-slow">
    <div class="flex flex-col">
      <h4 class="font-extrabold text-[#3d1d0e] text-xs">Listings</h4>
      <p class="text-[10px] text-gray-400 font-semibold">New listings - local MLS</p>
    </div>

    <div class="relative flex items-center justify-center h-24 w-24 mx-auto mt-2">
      <div 
        class="w-full h-full rounded-full flex items-center justify-center"
        style="background: conic-gradient(#ec4899 0% 25%, #6366f1 25% 75%, #f3f4f6 75% 100%);"
      >
        <div class="w-[74%] h-[74%] bg-white rounded-full flex flex-col items-center justify-center shadow-2xs">
          <span class="text-xs font-black text-[#3d1d0e] leading-none">75%</span>
          <span class="text-[8px] text-gray-400 font-bold uppercase tracking-tighter mt-0.5">Properties</span>
        </div>
      </div>
    </div>
  </div>
  </Hero>
  <TrustedBy />
  <GenericSection genericData={reOperations}/>
  <RolesSupported title={rolesSupported.title} description={rolesSupported.description} items={rolesSupported.items} />
  <HowItWorks />  
  <ClientReview />
  <section class="w-full bg-white py-16 px-6 md:py-24 md:px-12 text-[#3d1d0e]">
    <div class="max-w-7xl mx-auto flex flex-col gap-12 md:gap-16">
      
      <header class="text-center flex flex-col gap-4 max-w-3xl mx-auto">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight leading-tight text-[#3d1d0e]">
          Real Estate Expertise.<br />Operational Precision.
        </h2>
        <p class="text-gray-600 text-sm sm:text-base font-semibold leading-relaxed max-w-2xl mx-auto">
          YourServiceva’s real estate virtual assistants combine real estate expertise with operational best practices, helping your business work more efficiently.
        </p>
      </header>

      <div class="flex flex-wrap justify-center gap-6 w-full">
        
        <div class="bg-white rounded-2xl p-8 border border-gray-100/80 shadow-2xs flex flex-col items-center text-center gap-4 hover:shadow-xs transition-all duration-200 w-full md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] min-w-[280px]">
          <div class="text-brand-green flex-shrink-0 w-12 h-12 flex items-center justify-center mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127c.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.43l-1.003.754c-.29.219-.452.56-.452.93v.24c0 .37.162.711.452.93l1.003.754a1.125 1.125 0 0 1 .26 1.43l-1.296 2.247a1.125 1.125 0 0 1-1.37.49l-1.216-.456a1.125 1.125 0 0 0-1.076.124c-.072.044-.146.086-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.43l1.004-.754c.29-.218.452-.56.452-.93v-.24c0-.37-.162-.712-.452-.93l-1.004-.754a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.49l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128c.332-.183.582-.495.645-.869l.214-1.28Z" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-bold leading-snug tracking-tight text-[#3d1d0e]">
            Dedicated Task Specialists
          </h3>
          <p class="text-gray-500 text-sm font-medium leading-relaxed max-w-sm">
            Our virtual assistants have role specializations, ensuring their training matches the services your business needs.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-gray-100/80 shadow-2xs flex flex-col items-center text-center gap-4 hover:shadow-xs transition-all duration-200 w-full md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] min-w-[280px]">
          <div class="text-brand-green flex-shrink-0 w-12 h-12 flex items-center justify-center mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
              <text x="5.5" y="14.5" font-family="sans-serif" font-size="6" font-weight="900" fill="currentColor">24/7</text>
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-bold leading-snug tracking-tight text-[#3d1d0e]">
            24/7 Support for Listings & Maintenance
          </h3>
          <p class="text-gray-500 text-sm font-medium leading-relaxed max-w-sm">
            With 24/7 support, you can ensure all leads, listings, and inquiries are followed up in a timely manner.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-gray-100/80 shadow-2xs flex flex-col items-center text-center gap-4 hover:shadow-xs transition-all duration-200 w-full md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] min-w-[280px]">
          <div class="text-brand-green flex-shrink-0 w-12 h-12 flex items-center justify-center mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.5 7.5-3 3m0 0 1.5 1.5M13.5 10.5l-2-2" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-bold leading-snug tracking-tight text-[#3d1d0e]">
            Contract & Compliance Management
          </h3>
          <p class="text-gray-500 text-sm font-medium leading-relaxed max-w-sm">
            Our real estate virtual assistants can handle contract and compliance management, keeping everything compliant and accurate.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-gray-100/80 shadow-2xs flex flex-col items-center text-center gap-4 hover:shadow-xs transition-all duration-200 w-full md:w-[calc(50%-12px)] lg:w-[calc(50%-16px)] lg:max-w-[580px] min-w-[280px]">
          <div class="text-brand-green flex-shrink-0 w-12 h-12 flex items-center justify-center mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12h19.5m-19.5 0a6.75 6.75 0 0 1 13.5 0m-13.5 0a6.75 6.75 0 0 0 13.5 0m-13.5 0H15M12 3v18M3.75 6h16.5M3.75 18h16.5" />
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-bold leading-snug tracking-tight text-[#3d1d0e]">
            Bookkeeping & Financial Tracking
          </h3>
          <p class="text-gray-500 text-sm font-medium leading-relaxed max-w-md">
            Our dedicated real estate agents can manage all transactions in your business, including bookkeeping, bank reconciliations, and financial reporting.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-gray-100/80 shadow-2xs flex flex-col items-center text-center gap-4 hover:shadow-xs transition-all duration-200 w-full md:w-[calc(50%-12px)] lg:w-[calc(50%-16px)] lg:max-w-[580px] min-w-[280px]">
          <div class="text-brand-green flex-shrink-0 w-12 h-12 flex items-center justify-center mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94-3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            </svg>
          </div>
