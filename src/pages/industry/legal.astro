  }
]
}

const FAQs = {
  title: "Legal Virtual Assistant",
  description: "From specialized client intake coordinators to dedicated legal billing support staff.",
  questions: [
  {
    question: "What legal office tasks can I outsource to a virtual assistant?",
    answer: "You can outsource a broad spectrum of administrative tasks, including managing client intake lines, calendar management, updating billable hour logs, setting appointment reminders, sorting file indexing, and data entry into your legal practice software."
  },
  {
    question: "How do your legal virtual assistants handle client privacy and data confidentiality?",
    answer: "Confidentiality is fundamental. Our legal-focused virtual assistants follow strict security parameters, utilizing access proxies, restricted password managers, and logging into your secure, existing software via encrypted environments and MFA protocols."
  },
  {
    question: "Are your assistants experienced with standard legal practice management software?",
    answer: "Yes, our assistants are trained to adapt quickly to industry-standard modern software solutions such as Clio, MyCase, PracticePanther, Filevine, and common digital telephony layouts."
  },
  {
    question: "Can your staff draft legal pleadings or give legal advice?",
    answer: "No. Our assistants provide purely administrative support and do not practice law or give legal advice. They can help prepare, format, transcribe, and organize document files under the absolute direction and supervision of your firm's licensed attorneys."
  },
  {
    question: "How quickly can we integrate a specialist into our legal practice?",
    answer: "After an initial discovery consultation to pinpoint your specific operations and workflows, we can match your law firm with a dedicated administrative specialist within a few business days."
  }
]}

const Benefits = {
  title: "Why Outsourcing Legal Administration Works",
  description: "Optimize case file throughput, clear up outstanding collection lines, and minimize attorney burnout with specialized back-office support.",
  image: "https://images.unsplash.com/photo-1562564055-71e051d33c19?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  items: [
    {
      title: "Save 60–70% on administrative overhead",
      icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 15h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 17"/><path d="m7 21 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-5.4a2 2 0 0 0-3-2.7L15 13"/><path d="M5 22h14"/></svg>`
    },
    {
      title: "Reduce attorney documentation burnout",
      icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`
    },
    {
      title: "Strict data privacy compliance",
      icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>`
    },
    {
      title: "Accelerated case-file processing times",
      icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`
    },
    {
      title: "Scalable support for high case volumes",
      icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5"/><path d="M3 11v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V11"/><path d="M12 14v2"/></svg>`
    },
    {
      title: "Seamless new client intake experience",
      icon: `<svg xmlns="http://www.w3.org/2000/xl" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
    }
  ],
  slogan: "Legal Support Reimagined"
}
---

<Layout title="YourServiceva | Legal Industry Support">
  <Hero heroData={heroData}>
    
    <div class="absolute top-[-15%] md:top-[40%] -left-2 md:-left-10 sm:-left-12 z-20 bg-white/95 backdrop-blur-xs rounded-2xl p-4 shadow-xl border border-gray-100 flex flex-col gap-3 max-w-45 sm:max-w-52.5 animate-bounce-slow">
      <div class="flex items-center gap-2">
        <span class="text-brand-green text-lg">⚖️</span>
        <h4 class="font-extrabold text-[#3d1d0e] text-sm sm:text-md tracking-tight">Intake Desk</h4>
      </div>
      
      <div class="flex flex-col gap-2">
        <label class="flex items-center gap-2 bg-[#FAF8F5] px-3 py-2 rounded-xl border border-gray-100/80 cursor-pointer">
          <input type="checkbox" checked class="accent-brand-green h-4 w-4 rounded-sm" disabled />
          <span class="text-xs font-bold text-gray-600">Conflict Check Clear</span>
        </label>
        <label class="flex items-center gap-2 bg-[#FAF8F5] px-3 py-2 rounded-xl border border-gray-100/80 cursor-pointer">
          <input type="checkbox" checked class="accent-brand-green h-4 w-4 rounded-sm" disabled />
          <span class="text-xs font-bold text-gray-600">Retainer Signed</span>
        </label>
      </div>
    </div>

    <div class="hidden absolute -top-16 md:right-5 -right-16 z-20 bg-white/95 backdrop-blur-xs rounded-2xl p-4 shadow-xl border border-gray-100 md:flex flex-col gap-3 min-w-50 sm:min-w-60">
      <h4 class="font-extrabold text-[#3d1d0e] text-xs sm:text-sm tracking-tight border-b border-gray-50 pb-2">Case File Tracker</h4>
      
      <div class="flex flex-col gap-3">
        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <div class="h-8 w-8 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center font-bold text-xs">🏛️</div>
            <div class="flex flex-col">
              <span class="text-xs font-bold text-[#3d1d0e]">Pleading Submission</span>
              <span class="text-[10px] text-gray-400 font-medium">E-filing portal routing</span>
            </div>
          </div>
          <span class="text-xs font-black text-amber-500">Processing</span>
        </div>

        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <div class="h-8 w-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs">📂</div>
            <div class="flex flex-col">
              <span class="text-xs font-bold text-[#3d1d0e]">Discovery Intake Complete</span>
              <span class="text-[10px] text-gray-400 font-medium">Metadata indexed</span>
            </div>
          </div>
          <span class="text-xs font-black text-emerald-500">Ready</span>
        </div>

        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <div class="h-8 w-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center font-bold text-xs">📝</div>
            <div class="flex flex-col">
              <span class="text-xs font-bold text-[#3d1d0e]">Audio Transcription</span>
              <span class="text-[10px] text-gray-400 font-medium">Correspondence routed</span>
            </div>
          </div>
          <span class="text-xs font-black text-emerald-500">Sent</span>
        </div>
      </div>
    </div>

    <div class="absolute bottom-[-15%] md:bottom-[0%] -right-3 md:-right-8 sm:-right-12 z-20 bg-white/95 backdrop-blur-xs rounded-2xl p-4 shadow-xl border border-gray-100 flex flex-col gap-2 max-w-40 sm:max-w-47.5 [animation-delay:2s] animate-bounce-slow">
      <div class="flex flex-col">
        <h4 class="font-extrabold text-[#3d1d0e] text-xs">Firm Efficiency</h4>
        <p class="text-[10px] text-gray-400 font-semibold">Billable optimization</p>
      </div>

      <div class="relative flex items-center justify-center h-24 w-24 mx-auto mt-2">
        <div 
          class="w-full h-full rounded-full flex items-center justify-center"
          style="background: conic-gradient(#eab308 0% 15%, #22c55e 25% 85%, #f3f4f6 85% 100%);"
        >
          <div class="w-[74%] h-[74%] bg-white rounded-full flex flex-col items-center justify-center shadow-2xs">
            <span class="text-xs font-black text-[#3d1d0e] leading-none">85%</span>
            <span class="text-[8px] text-gray-400 font-bold uppercase tracking-tighter mt-0.5">Optimized</span>
          </div>
        </div>
      </div>
    </div>
  </Hero>
  <TrustedBy />
  <GenericSection genericData={legalOperations}/>
  <RolesSupported title={rolesSupported.title} description={rolesSupported.description} items={rolesSupported.items} />
  <HowItWorks />  
  <ClientReview />
  <BenefitsIndustry BenefitsData={Benefits} />
  <FAQ FAQs={FAQs}/>
</Layout>