---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Common/Hero.astro';
import TrustedBy from '../../components/Common/TrustedBy.astro';
import GenericSection from '../../components/Common/GenericSection.astro';
import HowItWorks from '../../components/Common/HowItWorks.astro';
import ClientReview from '../../components/Common/ClientReviews.astro';
import RolesSupported from '../../components/Common/RolesSupported.astro';
import BenefitsIndustry from '../../components/Common/BenefitsIndustry.astro';
import FAQ from '../../components/Common/FAQ.astro';

const heroData = {
  titleA: "Legal & Law Firm",
  titleB: "Virtual Assistants",
  items: [
    "Our trained legal virtual assistants help law firms, independent attorneys, and legal practices optimize operations by handling client intake, case management, document drafting, and administrative support.",
    "By offloading time-consuming calendar scheduling, court deadline tracking, and billing workflows, your legal team can eliminate administrative burnout and refocus entirely on billable tasks and winning cases."
  ],
  btn: {
    text: "Build Your Legal Support Team",
    link: "/contact?industry=legal"
  },
  photo: "https://images.unsplash.com/photo-1589829545856-d10d557cf95f?q=80&w=1470&auto=format&fit=crop",  
}

const legalOperations = {
  title: "Outsource Legal Administration to Maximize Billable Hours and Case Focus",
  description: "YourServiceva takes over the time-consuming administrative workflows, intake scheduling, and invoice coordination, allowing your attorneys and paralegals to focus entirely on litigation strategy and client advocacy. Our operations are tailored to uphold strict confidentiality standards and maximize firm efficiency.",
  image: "https://images.unsplash.com/photo-1603796846097-bee99e4a601f?q=80&w=1074&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  flow: "reverse",
  bg: "dark"
}

const rolesSupported = {
  title: "Legal Virtual Assistant Roles We Support",
  description: "Our specialized remote assistants integrate industry-leading practices into your legal practice management (LPM) systems and daily operational workflows. Here are some of our core services:",
  items: [
  {
    title: "Client intake, triaging & consultation booking",
    description: "Manage inbound case inquiries, gather initial client conflict-check data, perform baseline screening, and coordinate attorney consultation calendars.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg>`
  },
  {
    title: "Calendar management & court deadline tracking",
    description: "Coordinate critical calendar fixtures, send statutory deadline notifications, track hearing schedules, and update meeting itineraries.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>`
  },
  {
    title: "Legal billing, trust accounting & collections",
    description: "Generate clean client balance statements from logged billable hours, follow up on outstanding retainer invoices, and log invoice adjustments.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5Z" /></svg>`
  },
  {
    title: "File organization & document transcription",
    description: "Organize digital case charts, transcribe audio correspondence files, clean up pleading index layouts, and compile electronic discovery folders.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12" /></svg>`
  },
  {
    title: "Legal CRM upkeep & client communications",
    description: "Keep communication channels clear, update active case status tags, send regular case updates, and archive firm records seamlessly.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" /></svg>`
