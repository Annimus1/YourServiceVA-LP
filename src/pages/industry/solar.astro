const FAQs = {
  title: "Solar Virtual Assistant",
  description: "From virtual assistants and customer support to project coordination, marketing, and sales.",
  questions: [
  {
    question: "What solar operations tasks can I outsource?",
    answer: "You can outsource a wide range of administrative, operational, and pipeline tasks. This includes lead qualification, appointment setting, utility bill collection, solar CRM database maintenance, financial bookkeeping, project tracking for permitting, and social media management."
  },
  {
    question: "Can YourServiceva assist with permitting and utility coordination?",
    answer: "Yes, our specialized solar virtual assistants can handle project coordination workloads. They follow up on AHJ permit submissions, coordinate documentation for HOA requirements, and submit utility interconnection applications to ensure a faster Permission to Operate (PTO)."
  },
  {
    question: "Are your assistants trained in industry-standard solar tools?",
    answer: "Absolutely. Our solar virtual assistants come experienced or highly adaptive to clean-energy workflows. They can efficiently handle CRM management, document storage, scheduling logistics, and organizing consumer energy data sheets."
  },
  {
    question: "Do you handle logistical communications like customer notifications and scheduling?",
    answer: "Yes, we support field operations support. Our virtual assistants can reach out to homeowners for installation windows, coordinate milestone confirmations with engineering teams, log supply shortages, and update deployment timelines dynamically."
  },
  {
    question: "How quickly can I get started, and what are the costs?",
    answer: "Getting started is quick and straightforward. After an initial consultation to review your business needs, we match you with a trained specialist within a few days. Our pricing plans are flexible and tailored to the level of support and hours your team requires."
  }
]}

const Benefits = {
