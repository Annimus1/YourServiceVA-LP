---

<Layout title="YourServiceva | Healthcare Industry Support">
  <Hero heroData={heroData}>
    
    <div class="absolute top-[-15%] md:top-[40%] -left-2 md:-left-15 sm:-left-12 z-20 bg-white/95 backdrop-blur-xs rounded-2xl p-4 shadow-xl border border-gray-100 flex flex-col gap-3 md:max-w-80 max-w-52.5 animate-bounce-slow">
      <div class="flex items-center gap-2">
        <span class="text-brand-green text-lg md:text-xl">🏥</span>
        <h4 class="font-extrabold text-[#3d1d0e] text-md md:text-xl tracking-tight">Patient Desk</h4>
      </div>
      
      <div class="flex flex-col gap-2">
        <label class="flex items-center gap-2 bg-[#FAF8F5] px-3 py-2 rounded-xl border border-gray-100/80 cursor-pointer">
          <input type="checkbox" checked class="accent-brand-green h-4 w-4 rounded-sm" disabled />
          <span class="text-xs md:text-lg font-bold text-gray-600">Insurance Active</span>
        </label>
        <label class="flex items-center gap-2 bg-[#FAF8F5] px-3 py-2 rounded-xl border border-gray-100/80 cursor-pointer">
          <input type="checkbox" checked class="accent-brand-green h-4 w-4 rounded-sm" disabled />
          <span class="text-xs md:text-lg font-bold text-gray-600">Prior Auth Cleared</span>
        </label>
      </div>
    </div>

    <div class="hidden absolute -top-16 md:-right-25 -right-16 z-20 bg-white/95 backdrop-blur-xs rounded-2xl p-4 shadow-xl border border-gray-100 md:flex flex-col gap-3 md:min-w-70 min-w-60">
      <h4 class="font-extrabold text-[#3d1d0e] text-sm md:text-xl tracking-tight border-b border-gray-50 pb-2">Administrative Chart Tracker</h4>
      
      <div class="flex flex-col gap-3">
        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <div class="h-8 w-8 md:h-12 md:w-12 md:text-lg rounded-full bg-amber-100 text-amber-600 flex items-center justify-center font-bold text-xs">📋</div>
            <div class="flex flex-col">
              <span class="text-xs md:text-lg font-bold text-[#3d1d0e]">Claim Submission</span>
              <span class="text-[10px] md:text-[16px] text-gray-400 font-medium">Clearinghouse routing</span>
            </div>
          </div>
          <span class="text-xs md:text-[18px] font-black text-amber-500">Processing</span>
        </div>

        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <div class="h-8 w-8 md:w-12 md:h-12 md:text-lg rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs">🩺</div>
            <div class="flex flex-col">
              <span class="text-xs md:text-lg font-bold text-[#3d1d0e]">EHR Intake Complete</span>
              <span class="text-[10px] md:text-[16px] text-gray-400 font-medium">Demographics updated</span>
            </div>
          </div>
          <span class="text-xs md:text-[18px] font-black text-emerald-500">Ready</span>
        </div>

        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <div class="h-8 w-8 md:h-12 md:w-12 md:text-lg rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center font-bold text-xs">💊</div>
            <div class="flex flex-col">
              <span class="text-xs md:text-lg font-bold text-[#3d1d0e]">Refill Ticket Routed</span>
              <span class="text-[10px] md:text-[16px] text-gray-400 font-medium">Pending provider sign</span>
            </div>
          </div>
          <span class="text-xs md:text-[18px] font-black text-emerald-500">Sent</span>
        </div>
      </div>
    </div>

    <div class="absolute bottom-[-15%] md:bottom-[-18%] -right-3 md:-right-8 sm:-right-12 z-20 bg-white/95 backdrop-blur-xs rounded-2xl p-4 shadow-xl border border-gray-100 flex flex-col gap-2 md:max-w-90 max-w-47.5 [animation-delay:2s] animate-bounce-slow">
      <div class="flex flex-col w-full">
        <h4 class="font-extrabold md:text-lg text-[#3d1d0e] text-xs">Practice Volume</h4>
        <p class="text-[10px] md:text-[16px] text-gray-400 font-semibold md:text-no-wrap">Appointment optimization</p>
      </div>

      <div class="relative flex items-center justify-center h-24 w-24 md:h-36 md:w-36 mx-auto mt-2">
        <div 
          class="w-full h-full rounded-full flex items-center justify-center"
          style="background: conic-gradient(#22c55e 0% 15%, #22c55e 25% 85%, #f3f4f6 85% 100%);"
        >
          <div class="w-[74%] h-[74%] bg-white rounded-full flex flex-col items-center justify-center shadow-2xs">
            <span class="text-xs md:text-lg font-black text-[#3d1d0e] leading-none">85%</span>
            <span class="text-[8px] md:text-[18px] text-gray-400 font-bold uppercase tracking-tighter mt-0.5">Optimized</span>
          </div>
        </div>
      </div>
    </div>
  </Hero>

  <TrustedBy />
  <GenericSection genericData={healthcareOperations}/>
  <RolesSupported title={rolesSupported.title} description={rolesSupported.description} items={rolesSupported.items} />
  <HowItWorks />  
  <ClientReview />
  <BenefitsIndustry BenefitsData={Benefits} />
  <FAQ FAQs={FAQs}/>
</Layout>