const FAQs = {
  title: "Medical Virtual Assistant",
  description: "From certified patient intake specialists to dedicated medical billing support staff.",
  questions: [
  {
    question: "What medical office tasks can I outsource to a virtual assistant?",
    answer: "You can outsource a broad spectrum of administrative tasks, including medical scheduling, live patient recall check-ins, insurance eligibility verification, claims processing follow-ups, and managing basic records in your EHR platform."
  },
  {
    question: "How do your medical virtual assistants handle patient privacy and HIPAA guidelines?",
    answer: "Compliance and security are fundamental. Our healthcare-focused virtual assistants undergo comprehensive data privacy orientation, logging into your secure, existing EHR infrastructure through encrypted environments and MFA protocols."
  },
  {
    question: "Are your assistants experienced with standard EHR and medical software?",
    answer: "Yes, our assistants are trained to adapt quickly to industry-standard modern applications such as Athenahealth, Practice Fusion, eClinicalWorks, SimplePractice, and common digital telephony layouts."
  },
  {
    question: "Can your staff help manage prescription refills or pharmacy follow-ups?",
    answer: "Our assistants handle administrative processing. They can compile incoming refill inquiries from patients or pharmacies, log them cleanly into the patient’s chart, and present them directly to your licensed provider for clinical approval."
  },
  {
    question: "How quickly can we integrate a specialist into our medical practice?",
    answer: "After an initial discovery consultation to pinpoint your specific care workflows, we can match your clinic with a dedicated administrative specialist within a few business days."
