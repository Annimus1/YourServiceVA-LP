  titleB: "Virtual Assistants",
  items: [
    "Our HIPAA-compliant medical virtual assistants help practices, clinics, telehealth providers, and specialists optimize patient care pipelines by handling scheduling, insurance verification, medical billing, and administrative documentation.",
    "By offloading time-consuming front-desk operations and charting workflows, your clinical team can eliminate administrative burnout and refocus entirely on deliver-quality patient health outcomes."
  ],
  btn: {
    text: "Build Your Healthcare Support Team",
    link: "/contact?industry=healthcare"
  },
  photo: "/img/pages/hc.webp",
}
const healthcareOperations = {
  title: "Outsource Healthcare Administration to Reduce Burnout and Improve Patient Care",
  description: "YourServiceva takes over the time-consuming administrative workflows, front-desk scheduling, and billing coordination, allowing your clinical staff to focus entirely on patient health outcomes. Our operations are tailored to uphold data privacy standards and maximize practice efficiency.",
  image: "/img/pages/hc2.webp",
  flow: "reverse",
  bg: "dark"
}
