<script>
  const toggle = document.getElementById('billing-toggle') as HTMLInputElement;
  const prices = document.querySelectorAll('.price-card');
  const labelPt = document.getElementById('label-pt');
  const labelFt = document.getElementById('label-ft');

  function updatePrices() {
    const isFullTime = toggle.checked;
    
    if (isFullTime) {
      labelFt?.classList.add('text-brand-green');
      labelFt?.classList.remove('text-gray-400');
      labelPt?.classList.add('text-gray-400');
      labelPt?.classList.remove('text-brand-green');
    } else {
      labelPt?.classList.add('text-brand-green');
      labelPt?.classList.remove('text-gray-400');
      labelFt?.classList.add('text-gray-400');
      labelFt?.classList.remove('text-brand-green');
    }

    prices.forEach((price) => {
      const element = price as HTMLElement;
      const ptValue = element.getAttribute('data-pt');
      const ftValue = element.getAttribute('data-ft');
      const rawPrice = isFullTime ? ftValue : ptValue;

      if (rawPrice) {
        const [integer, decimals] = rawPrice.split('.');
        element.innerHTML = `${integer}<span class="text-2xl font-bold self-start mt-1">.${decimals}</span>`;
      }
    });
  }

  toggle?.addEventListener('change', updatePrices);
  
  if(toggle) {
    updatePrices();
  }
</script>