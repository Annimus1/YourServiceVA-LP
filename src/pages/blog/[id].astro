---
import Layout from '../../layouts/Layout.astro';
import { getPostById, getPosts } from '../../lib/posts';

export function getStaticPaths() {
  const posts = getPosts();
  return posts.map((post) => ({
    params: { id: post.id },
  }));
}

const { id } = Astro.params;
const post = getPostById(id);

if (!post) {
  return Astro.redirect('/404');
}

const formattedDate = "Feb 24, 2026";
---

<Layout title={`${post.title} - YourServiceVA`}>
  <main class="max-w-7xl mx-auto px-6 py-12 text-[#3d1d0e]">
    
    {post.image && (
      <header 
        class="w-full h-[400px] md:h-120 rounded-3xl overflow-hidden bg-cover bg-center relative flex items-end mb-12 shadow-md"
        style={`background-image: linear-gradient(to top, rgba(0, 114, 176, 0.95) 10%, rgba(61, 29, 14, 0.4) 60%, rgba(0,0,0,0) 100%), url(${post.image});`}
      >
        <div class="p-8 md:p-12 w-full max-w-4xl coordinate-z">
          <div class="flex items-center gap-3 text-xs md:text-sm font-extrabold uppercase tracking-wider text-brand-green mb-3">
            <span>{post.service}</span>
            <span class="w-1.5 h-1.5 rounded-full bg-white/50"></span>
            <span class="text-gray-300 normal-case font-medium">{formattedDate}</span>
          </div>
          
          <h1 class="text-3xl md:text-5xl font-black tracking-tight leading-tight text-white">
            {post.title}
          </h1>
        </div>
      </header>
    )}

    {!post.image && (
      <header class="mb-12 max-w-3xl">
        <h1 class="text-4xl font-extrabold text-brand-green mb-4 tracking-tight">
          {post.title}
        </h1>
      </header>
    )}

    <div class="w-full flex flex-col gap-12">
      
      <p class="text-xl text-gray-500 font-medium leading-relaxed max-w-6xl">
        {post.description}
      </p>

      <div class="flex flex-col gap-12 border-t border-gray-100 pt-10">
        {post.content.map((item) => (
          <section class="flex flex-col gap-4 max-w-4xl">
            
            <h2 class="text-2xl md:text-2xl font-bold text-brand-green tracking-tight mb-6">
              {item.title}
            </h2>
            
            {
                item.description.map((paragraph) => (
                    <p class="text-gray-600 text-base md:text-lg leading-relaxed font-medium whitespace-pre-line mb-6">
                        {paragraph}
                    </p>
                ))
            }
            
            {item.image && (
              <div class="w-full aspect-video rounded-2xl overflow-hidden bg-gray-50 mt-2 border border-gray-100 shadow-xs">
                <img 
                  src={item.image} 
                  alt={item.title} 
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            )}
            
          </section>
        ))}
      </div>

    </div>
  </main>
</Layout>
