---
import Layout from '../../layouts/Layout.astro'; // Ajusta la ruta relativa si está en src/pages/blog/index.astro
import { getPosts } from '../../lib/posts';

interface Post {
  id: string;
  title: string;
  description: string;
  image?: string;
  service?: string;
  Industry?: string;
}

// Traemos absolutamente todos los posts en tiempo de compilación
const allPosts: Post[] = getPosts();
---

<Layout title="Blog & Resources - YourServiceVA">
  <main class="bg-[#FAF8F5] min-h-screen py-16 px-6 md:px-12">
    <div class="max-w-7xl mx-auto flex flex-col gap-12">
      
      <header class="text-center md:text-left flex flex-col gap-3">
        <h1 class="text-4xl md:text-5xl font-black text-[#3d1d0e] tracking-tight">
          Our Blog & Resources
        </h1>
        <p class="text-gray-500 font-semibold text-base md:text-lg max-w-2xl leading-relaxed">
          Stay up to date with the latest insights, statistics, and guides regarding remote infrastructure and virtual assistance.
        </p>
      </header>

      {/* Grid de Posts: Les añadimos un atributo de datos para controlarlos con JS */}
      <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {allPosts.map((post, index) => (
          <article 
            data-index={index}
            class="post-card bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-xs flex flex-col hover:shadow-md transition-shadow duration-300 hidden"
          >
            <div class="w-full aspect-16/10 bg-gray-100 relative overflow-hidden">
              {post.image ? (
                <img 
                  src={post.image} 
                  alt={post.title} 
                  class="w-full h-full object-cover transition-transform duration-500 hover:scale-102"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-gray-200 text-gray-400">
                  No Image Available
                </div>
              )}
            </div>

            <div class="p-6 flex flex-col flex-1 gap-4">
              <div class="flex flex-wrap items-center gap-2">
                {post.service && (
                  <span class="bg-[#0066cc]/10 text-[#0066cc] font-extrabold text-[10px] px-2.5 py-1 rounded-sm tracking-widest uppercase">
                    {post.service}
                  </span>
                )}
                {post.Industry && (
                  <span class="bg-brand-green/10 text-brand-green font-extrabold text-[10px] px-2.5 py-1 rounded-sm tracking-widest uppercase">
                    {post.Industry}
                  </span>
                )}
                <span class="text-gray-400 text-xs font-semibold ml-auto">
                  5 min read
                </span>
              </div>

              <h2 class="text-xl font-bold text-[#3d1d0e] tracking-tight leading-snug line-clamp-2 hover:text-[#0066cc] transition-colors">
                <a href={`/blog/${post.id}`}>
                  {post.title}
                </a>
              </h2>

              <p class="text-gray-500 text-sm font-medium leading-relaxed line-clamp-3">
                {post.description}
              </p>

              <div class="mt-auto pt-4 border-t border-gray-50 flex items-center justify-between">
                <span class="text-gray-400 text-xs font-medium">March 12, 2026</span>
                <a 
                  href={`/blog/${post.id}`} 
                  class="text-xs font-black text-[#3d1d0e] uppercase tracking-wider hover:text-brand-green transition-colors inline-flex items-center gap-1 group"
                >
                  Read Article
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 transition-transform group-hover:translate-x-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      {/* --- CONTROLES DE PAGINACIÓN JAVASCRIPT --- */}
      <nav id="pagination-controls" class="flex items-center justify-center gap-2 mt-8 pt-8 border-t border-gray-100 hidden">
        {/* Botón Anterior */}
        <button 
          id="prev-btn"
          class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-gray-200 text-[#3d1d0e] hover:border-[#0066cc] hover:text-[#0066cc] transition-all cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
          aria-label="Previous page"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
        </button>

        {/* Texto Informativo */}
        <span id="page-indicator" class="text-sm font-bold text-[#3d1d0e] px-4 py-2 bg-white border border-gray-100 rounded-xl shadow-xs">
          Page 1 of 1
        </span>

        {/* Botón Siguiente */}
        <button 
          id="next-btn"
          class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-gray-200 text-[#3d1d0e] hover:border-[#0066cc] hover:text-[#0066cc] transition-all cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
          aria-label="Next page"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </button>
      </nav>

    </div>
  </main>
</Layout>

<script>
  // Lógica de paginación en el cliente
  const POSTS_PER_PAGE = 9;
  let currentPage = 1;

  const cards = document.querySelectorAll('.post-card');
  const totalPosts = cards.length;
  const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);

  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const pageIndicator = document.getElementById('page-indicator');
  const paginationControls = document.getElementById('pagination-controls');

  function updatePagination() {
    // Calcular límites de visualización
    const start = (currentPage - 1) * POSTS_PER_PAGE;
    const end = start + POSTS_PER_PAGE;

    // Mostrar u ocultar tarjetas según el índice
    cards.forEach((card) => {
      const index = parseInt(card.getAttribute('data-index') || '0', 10);
      if (index >= start && index < end) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });

    // Actualizar estados de botones
    if (prevBtn && nextBtn && pageIndicator) {
      prevBtn.disabled = currentPage === 1;
      nextBtn.disabled = currentPage === totalPages;
      pageIndicator.textContent = `Page ${currentPage} of ${totalPages}`;
    }
  }

  // Inicializar solo si hay posts y se requiere paginación
  if (totalPosts > 0) {
    if (totalPages > 1 && paginationControls) {
      paginationControls.classList.remove('hidden');
    }
    updatePagination();

    // Listeners para los botones
    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        updatePagination();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    nextBtn?.addEventListener('click', () => {
      if (currentPage < totalPages) {
        currentPage++;
        updatePagination();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  }
</script>