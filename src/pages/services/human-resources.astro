---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Human Resources Services | Your Service VA" description="Discover our Human Resources services, designed to streamline your HR processes and enhance employee management. From recruitment to payroll, we provide comprehensive solutions to support your business growth.">
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 max-w-7xl">
      <h1 class="text-4xl font-bold mb-6">Human Resources Services</h1>
      <p class="text-lg mb-4">Our Human Resources services are tailored to help businesses manage their workforce effectively. We offer a range of solutions including recruitment, employee onboarding, payroll management, and compliance support. Let us handle your HR needs so you can focus on growing your business.</p>
    </div>
  </section>
</Layout>
