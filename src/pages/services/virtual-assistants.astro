---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Common/Hero.astro';
import TrustedBy from '../../components/Common/TrustedBy.astro';
import GenericSection from '../../components/Common/GenericSection.astro';
import HowItWorks from '../../components/Common/HowItWorks.astro';
import ClientReviews from '../../components/Common/ClientReviews.astro';
import TalentsSection from '../../components/VirtualAssistant/TalentsSection.astro';
import FAQ from '../../components/Common/FAQ.astro';

const heroData = {
  titleA: "Virtual Assistant Services",
  titleB: "for Visionary Leaders",
  btn: {
    text: "Get Your Virtual Assistant",
    link: "/contact"
  },
  items : [
    "Remote CoWorker’s virtual assistant services keep your business running efficiently, from inbox maintenance and scheduling to customer support and sales.", 
    ],
  photo: "https://images.unsplash.com/photo-1699720213651-43e663f2d4b0?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
}

const findAndHire = {
  title: "Find and Hire Talent with Virtual Assistant Outsourcing",
  description: "Hire virtual assistants to help with live chat, support, sales, marketing, bookkeeping, and more. Our experienced account managers will assess your needs, line up potential assistants, assist with interviews, and follow up to ensure your assistant is meeting your needs.",
  image: "https://images.unsplash.com/photo-1752650735951-7724818b3487?q=80&w=1331&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  flow: "reverse"
} 

const FAQs ={
  title: "Virtual Assistant Services",
  description:"From virtual assistants and customer support to sales, marketing, bookkeeping, and tech.",
  questions: [
    {
      question: "What types of tasks can your VAs handle?",
      answer: "Our virtual assistants are cross-trained to manage a wide array of specialized operations, including executive administrative support, inbox and calendar management, professional bookkeeping (QuickBooks, invoicing), live chat, customer retention support, CRM management, and industry-specific legal assistance (case filing and legal drafting)."
    },
    {
      question: "How fast can I get started?",
      answer: "You can get started almost immediately. Once we complete your initial strategic onboarding and definition of workflows, we match you with a pre-trained specialist within 24 to 48 hours, ensuring a seamless integration into your business layout."
    },
    {
      question: "Are your VAs dedicated or shared?",
      answer: "We focus on providing dedicated virtual assistants. This means your assigned specialist works exclusively on your business workflows, tools, and operational schedules, allowing them to thoroughly integrate into your company culture and build consistent performance metrics."
    },
    {
      question: "Can I scale hours up or down later?",
      answer: "Yes, our operational model is completely flexible. You can request to scale your allocated assistant hours up or adjust your team capacity based on seasonal demands by providing a proper strategic notice as outlined in your initial Statement of Work (SOW)."
    },
    {
      question: "How do I communicate my VA's work?",
      answer: "You maintain full direct communication with your remote staff. You can manage tasks and touch base daily via your preferred communication infrastructure, whether that involves Slack, Microsoft Teams, Zoom, email, or your internal corporate task management dashboards."
    },
    {
      question: "How can I track my VA's performance and time?",
      answer: "We employ robust tracking frameworks and transparent time-logging protocols. Your virtual assistant documents their operational tasks in real time, giving you comprehensive summaries, transparency in productivity metrics, and exact hour-by-hour task resolution logs."
    }
  ]
}
---

<Layout title="YourServiceva | Virtual Assistants Services">
  <Hero heroData={heroData} >
    <div class="absolute top-0 md:top-8  right-44 md:right-0 sm:right-4 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 md:flex flex-col gap-2 min-w-40 sm:min-w-47.5 animate-bounce-slow">
      <div class="flex items-center justify-between text-xs font-bold text-gray-400">
        <span>To-do</span>
        <span class="h-5 w-5 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center">1</span>
      </div>
      <label class="flex items-center gap-2 text-[11px] sm:text-xs font-medium text-gray-400 line-through decoration-gray-300">
        <input type="checkbox" checked disabled class="rounded text-purple-600 focus:ring-0 h-3.5 w-3.5" />
          Client Call - 2:00 PM
        </label>
      <label class="flex items-center gap-2 text-[11px] sm:text-xs font-semibold text-gray-700">
      <input type="checkbox" checked disabled class="rounded text-emerald-500 focus:ring-0 h-3.5 w-3.5" />
        Follow-Up Emails - 4:00 PM
      </label>
    </div>

    <div class="hidden absolute bottom-24 left-0 md:-left-14 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 max-w-50 sm:max-w-60 md:flex flex-col gap-2">
      <div class="flex items-center gap-2 border-b border-gray-100 pb-1.5">
        <div class="h-6 w-6 rounded-full bg-sky-200 text-[10px] font-bold flex items-center justify-center">GN</div>
        <div class="flex flex-col">
          <span class="text-[11px] font-bold text-gray-800 leading-none">George Nielsen</span>
          <span class="text-[9px] text-gray-400">President of Sales</span>
        </div>
      </div>
      <p class="text-[10px] sm:text-[11px] font-medium text-gray-600 bg-gray-50 rounded-lg p-2">
        Hi! Thanks for reaching out. How can I assist you today?
      </p>
      <p class="text-[10px] sm:text-[11px] font-semibold text-white bg-brand-blue rounded-lg p-2 self-end text-right">
        Hi! can you help book a new reservation under my account?
      </p>
    </div>

    <div class="absolute -bottom-6 md:bottom-6 right-0 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 flex flex-col gap-2 min-w-37.5 sm:min-w-45">
      <div class="flex items-center gap-1.5 text-xs font-bold text-gray-800">
        <span class="text-brand-blue">📬</span> Email Inbox <span class="text-brand-green font-extrabold">(2)</span>
      </div>
      <div class="flex flex-col gap-1 text-[10px] font-medium text-gray-500">
        <div class="p-1.5 bg-gray-50 rounded border-l-2 border-brand-green text-gray-700 font-semibold">Stay connected with team</div>
        <div class="p-1.5 bg-gray-50 rounded border-l-2 border-brand-blue">When the huddle is over</div>
      </div>
    </div>
  </Hero>
  <TrustedBy />
  <GenericSection genericData={findAndHire} />
  <TalentsSection />
  <HowItWorks />
  <ClientReviews />
  <FAQ FAQs={FAQs} />
</Layout>