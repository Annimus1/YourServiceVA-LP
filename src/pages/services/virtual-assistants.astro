---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Common/Hero.astro';
import TrustedBy from '../../components/Common/TrustedBy.astro';
import GenericSection from '../../components/Common/GenericSection.astro';
import HowItWorks from '../../components/Common/HowItWorks.astro';
import ClientReviews from '../../components/Common/ClientReviews.astro';
import TalentsSection from '../../components/Common/TalentsSection.astro';
import FAQ from '../../components/Common/FAQ.astro';

const heroData = {
  titleA: "Virtual Assistant Services",
  titleB: "for Visionary Leaders",
  btn: {
    text: "Get Your Virtual Assistant",
    link: "/contact?service=virtual-assistants"
  },
  items : [
    "Remote CoWorker’s virtual assistant services keep your business running efficiently, from inbox maintenance and scheduling to customer support and sales.", 
    ],
  photo: "/img/pages/va.webp"
}
const findAndHire = {
  title: "Find and Hire Talent with Virtual Assistant Outsourcing",
  description: "Hire virtual assistants to help with live chat, support, sales, marketing, bookkeeping, and more. Our experienced account managers will assess your needs, line up potential assistants, assist with interviews, and follow up to ensure your assistant is meeting your needs.",
  image: "/img/pages/va2.webp",
  flow: "reverse",
  bg: "dark"
} 
const FAQs = {
  title: "Virtual Assistant Services",
  description: "From virtual assistants and customer support to sales, marketing, bookkeeping, and tech.",
  questions: [
    {
      question: "What types of tasks can your VAs handle?",
      answer: "Our virtual assistants are highly adaptable and cross-trained to bring peace of mind to your daily operations. They handle executive administrative support, proactive inbox and calendar management, professional bookkeeping (QuickBooks, invoicing), live chat, CRM management, and industry-specific legal assistance with absolute care and attention to detail."
    },
    {
      question: "How fast can I get started?",
      answer: "You can get started almost immediately. Once we complete your initial onboarding and understand your workflows, we match you with an eager, pre-trained specialist within 24 to 48 hours, ensuring a smooth, warm, and stress-free integration into your business."
    },
    {
      question: "Do you offer multichannel and 24/7 coverage?",
      answer: "Yes. Our diverse talent pool includes multichannel assistants ready to support your business across different time zones. Whether you need calendar coverage during standard hours or overnight support, our VAs maintain a reliable, helpful, and positive attitude whenever you need them."
    },
    {
      question: "What platforms and tools do your VAs use?",
      answer: "Our assistants are natural tech-learners and come ready-certified or highly experienced in standard business software like Zendesk, HubSpot, Salesforce, Slack, QuickBooks, and popular project management tools (Asana, ClickUp). They easily adapt to your internal workflows and specific corporate toolsets during onboarding."
    },
    {
      question: "Are your VAs dedicated or shared?",
      answer: "We focus strictly on providing dedicated virtual assistants. This means your assigned specialist works exclusively for your brand, allowing them to truly connect with your company culture, understand your values, and build a meaningful, long-term working relationship with your team."
    },
    {
      question: "How do you ensure quality and performance?",
      answer: "We ensure excellence through continuous encouragement and leadership. Our team leads regularly check in on workflows, provide helpful feedback, and monitor progress to make sure your assistant is supported, motivated, and consistently meeting your quality expectations."
    },
    {
      question: "Can I scale hours up or down later?",
      answer: "Absolutely. Our model is built to grow alongside your business. If you experience seasonal demands or temporary spikes in workload, our flexible framework allows you to easily scale up your assistant hours or adjust team capacity by providing proper strategic notice."
    },
    {
      question: "How do I communicate with my VA daily?",
      answer: "You maintain direct, close communication with your assistant. They are always ready to collaborate and touch base using your preferred tools—whether that means jumping on a Zoom call, messaging via Slack or Microsoft Teams, or coordinating through your internal dashboards."
    },
    {
      question: "How can I track my VA's time and tasks?",
      answer: "We prioritize complete transparency and trust. Your virtual assistant documents their operational tasks and hours in real time, providing you with clear, comprehensive summaries and progress reports so you always know exactly how they are helping your business succeed."
    }
  ]
}
---

<Layout title="YourServiceva | Virtual Assistants Services">
  <Hero heroData={heroData} >
    <div class="absolute top-0 md:top-8  right-44 md:-right-20 sm:right-4 bg-brand-dark-blue backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-600 z-20 md:flex flex-col gap-2 min-w-40 sm:min-w-47.5 animate-bounce-slow">
      <div class="flex items-center justify-between text-xs md:text-lg font-bold text-gray-100">
        <span>To-do</span>
        <span class="h-5 w-5 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center">1</span>
      </div>
      <label class="flex items-center gap-2 text-xs md:text-[14px] font-medium text-gray-400 line-through decoration-gray-300">
        <input type="checkbox" checked disabled class="rounded text-purple-600 focus:ring-0 h-3.5 w-3.5" />
          Client Call - 2:00 PM
        </label>
      <label class="flex items-center gap-2 text-xs md:text-[14px] font-semibold text-white">
      <input type="checkbox" checked disabled class="rounded text-emerald-500 focus:ring-0 h-3.5 w-3.5" />
        Follow-Up Emails - 4:00 PM
      </label>
    </div>

    <div class="hidden absolute -bottom-10 left-0 md:-left-14 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 max-w-60 md:max-w-70 md:flex flex-col gap-2">
      <div class="flex items-center gap-2 border-b border-gray-100 pb-1.5">
        <div class="h-8 w-8 rounded-full bg-sky-200 text-[10px] md:text-lg font-bold flex items-center justify-center">GN</div>
        <div class="flex flex-col">
          <span class="text-[11px]  md:text-lg font-bold text-gray-800 leading-none">George Nielsen</span>
          <span class="text-[9px] md:text-[14px] text-gray-400">President of Sales</span>
        </div>
      </div>
      <p class="text-[11px] md:text-[14px] font-medium text-gray-600 bg-gray-50 rounded-lg p-2">
        Hi! Thanks for reaching out. How can I assist you today?
      </p>
      <p class="text-[11px] md:text-[14px] font-semibold text-white bg-brand-blue rounded-lg p-2 self-end text-right">
        Hi! can you help book a new reservation under my account?
      </p>
    </div>

    <div class="absolute -bottom-6 md:bottom-20 right-0 md:-right-10 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 flex flex-col gap-2 min-w-37.5 sm:min-w-45">
      <div class="flex items-center gap-1.5 text-xs md:text-lg font-bold text-gray-800">
        <span class="text-brand-blue">📬</span> Email Inbox <span class="text-brand-green font-extrabold">(2)</span>
      </div>
      <div class="flex flex-col gap-1 text-[10px] md:text-[14px] font-medium text-gray-500">
        <div class="p-1.5 bg-gray-50 rounded border-l-2 border-brand-green text-gray-700 font-semibold">Stay connected with team</div>
        <div class="p-1.5 bg-gray-50 rounded border-l-2 border-brand-blue">When the huddle is over</div>
      </div>
    </div>
  </Hero>
  <TrustedBy />
  <GenericSection genericData={findAndHire} />
  <TalentsSection />
  <HowItWorks />
  <ClientReviews />
  <FAQ FAQs={FAQs} />
</Layout>