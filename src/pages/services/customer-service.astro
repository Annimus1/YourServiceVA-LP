---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Common/Hero.astro';
import TrustedBy from '../../components/Common/TrustedBy.astro';
import GenericSection from '../../components/Common/GenericSection.astro';
import HowItWorks from '../../components/Common/HowItWorks.astro';
import ClientReviews from '../../components/Common/ClientReviews.astro';
import TalentsSection from '../../components/Common/TalentsSection.astro';
import FAQ from '../../components/Common/FAQ.astro';

const heroData = {
  titleA: "Omnichannel Customer",
  titleB: "Support Specialists",
  btn: {
    text: "Build Your Support Team",
    link: "/contact?service=customer-service"
  },
  items : [
    "Elevate your customer experience with a team that truly cares. Our dedicated support specialists are rigorously trained to understand your brand inside and out, providing empathetic and personalized assistance.", 
    "Beyond just answering tickets, our agents bring a proactive, problem-solving attitude to every interaction. We take pride in delivering swift and genuinely helpful responses that make your customers feel valued.",
    "Build lasting relationships through exceptional service. With a strong commitment to excellence, our team ensures every inquiry is handled with the utmost professionalism, patience, and attention to detail."
  ],
  photo: "/img/pages/cs1.webp"
}

const findAndHire = {
  title: "Scale Your Support Operations with Dedicated Talent",
  description: "Stop struggling with missed tickets and long wait times. Hire specialized customer service agents trained in live chat support, tier-1 technical assistance, dispute resolution, and CRM ticket management. Our experienced account managers line up top-tier specialists, assist with standard onboarding, and track QA metrics to ensure your customers receive world-class care.",
  image: "/img/pages/cs2.webp",
  flow: "reverse",
  bg: "dark"
} 

const FAQs = {
  title: "Customer Support Services",
  description: "From live chat agents and helpdesk management to escalation resolution and omnichannel care.",
  questions: [
    {
      question: "What channels can your customer service specialists handle?",
      answer: "Our support agents are fully omnichannel. They are trained to bring a warm, empathetic, and human touch across live chat platforms (Intercom, Zendesk Chat), email ticketing desks, inbound and outbound phone support, social media messages, and community moderation workflows."
    },
    {
      question: "How fast can I launch my support team?",
      answer: "We can quickly match you with fully vetted professionals ready to align with your business. Once we map out your brand's unique values and workflows, our eager and pre-trained agents can seamlessly integrate into your operations in just a few days."
    },
    {
      question: "Do you offer multichannel and 24/7 coverage?",
      answer: "Yes. We have a diverse talent pool of multichannel specialists ready to support your global audience around the clock. Our teams are committed to maintaining a patient, helpful attitude and outstanding service standards, no matter the time zone."
    },
    {
      question: "Are the agents already trained in standard helpdesk software?",
      answer: "Absolutely. Our agents come highly experienced or ready-certified in standard infrastructure like Zendesk, Freshdesk, HubSpot, and Salesforce. They are natural problem-solvers who quickly master your internal knowledge bases, specific macros, and brand guidelines during onboarding."
    },
    {
      question: "Will I get dedicated support agents or shared staff?",
      answer: "We focus strictly on dedicated customer service specialists. Your assigned team members work exclusively for your brand, allowing them to truly connect with your vision, thoroughly learn your products, and represent your unique corporate tone of voice with genuine care."
    },
    {
      question: "How do you handle Quality Assurance (QA) and monitoring?",
      answer: "We ensure excellence through constant guidance and encouragement. Our team leads regularly monitor ticket interactions and live chat logs, prioritizing comprehensive feedback to help our agents maintain the highest standards of helpfulness, accuracy, and customer appreciation."
    },
    {
      question: "Can we scale our support team for holiday seasons or peak traffic?",
      answer: "Yes, our operational model adapts beautifully to your growth. If you expect a seasonal spike in traffic, our prepared talent pool makes it incredibly simple to scale up your team size, bringing in extra hands with the same proactive, positive attitude your customers deserve."
    },
    {
      question: "What is the typical resolution time metric?",
      answer: "While exact speed depends on your software's settings, our human-centric approach targets rapid and efficient responses. Our agents are specifically trained to provide prompt first-response times (FRT) on live chat and email without ever sacrificing the thoroughness and empathy of the interaction."
    }
  ]
}
---

<Layout title="YourServiceva | Omnichannel Customer Support Services">
  <Hero heroData={heroData} >
    
    <div class="absolute -top-14.5 md:top-8 right-32 md:right-36 sm:right-4 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 md:flex flex-col gap-2 md:min-w-40 min-w-47.5 animate-bounce-slow">
      <div class="flex items-center justify-between text-xs md:text-lg font-bold text-gray-400">
        <span>Queue Status</span>
        <span class=" px-2 py-1 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center font-extrabold text-[10px]">Active</span>
      </div>
      <label class="flex items-center gap-2 text-xs md:text-md font-medium text-gray-400 line-through decoration-gray-300">
        <input type="checkbox" checked disabled class="rounded text-brand-green focus:ring-0 h-3.5 w-3.5 md:text-lg" />
          Ticket #1084 Resolved
        </label>
      <label class="flex items-center gap-2 text-xs md:text-md font-semibold text-gray-700">
        <span class="animate-pulse h-2 w-2 rounded-full bg-orange-500"></span>
        <span class="text-orange-600 font-bold">[Priority]</span> SLA Escalate - 5m
      </label>
    </div>

    <div class="hidden absolute bottom-0 left-0 md:-left-14 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 md:max-w-56 max-w-60 md:flex flex-col gap-2">
      <div class="flex items-center gap-2 border-b border-gray-100 pb-1.5">
        <div class="h-6 w-6 rounded-full bg-emerald-200 text-[10px] font-bold flex items-center justify-center text-emerald-800">CS</div>
        <div class="flex flex-col">
          <span class="text-[11px] md:text-lg font-bold text-gray-800 leading-none">Customer Support</span>
          <span class="text-[9px] md:text-md text-brand-green font-semibold">Agent Online</span>
        </div>
      </div>
      <p class="text-[11px] md:text-md font-medium text-gray-600 bg-gray-50 rounded-lg p-2">
        Hi there! Thanks for reaching out. How can I assist you today?
      </p>
      <p class="text-[11px] md:text-md font-semibold text-white bg-brand-blue rounded-lg p-2 self-end text-right">
        Hi! Can you help me check my order delivery status?
      </p>
    </div>

    <div class="absolute bottom-0 md:bottom-6 -right-4 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 flex flex-col gap-2 min-w-37.5 sm:min-w-45">
      <div class="flex items-center gap-1.5 text-xs md:text-lg font-bold text-gray-800">
        <span class="text-brand-blue">📥</span> Shared Helpdesk <span class="text-orange-500 font-extrabold">(3 New)</span>
      </div>
      <div class="flex flex-col gap-1 text-[10px] font-medium text-gray-500">
        <div class="p-1.5 bg-gray-50 md:text-[16px] rounded border-l-2 border-orange-500 text-gray-700 font-semibold">Refund request requested</div>
        <div class="p-1.5 bg-gray-50 md:text-[16px] rounded border-l-2 border-brand-blue">Subscription plan change</div>
      </div>
    </div>
    
  </Hero>
  <TrustedBy />
  <GenericSection genericData={findAndHire} />
  <TalentsSection />
  <HowItWorks />
  <ClientReviews />
  <FAQ FAQs={FAQs} />
</Layout>