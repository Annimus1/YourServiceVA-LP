---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Common/Hero.astro';
import TrustedBy from '../../components/Common/TrustedBy.astro';
import GenericSection from '../../components/Common/GenericSection.astro';
import HowItWorks from '../../components/Common/HowItWorks.astro';
import ClientReviews from '../../components/Common/ClientReviews.astro';
import TalentsSection from '../../components/Common/TalentsSection.astro';
import FAQ from '../../components/Common/FAQ.astro';

const heroData = {
  titleA: "High-Performance VICIdial",
  titleB: "Predictive Dialer Infrastructure",
  btn: {
    text: "Deploy Your Dialer Solution",
    link: "/contact"
  },
  items : [
    "Maximize your agent talk time and crush idle metrics. Our enterprise-grade VICIdial configurations power up to 20 simultaneous lines per agent, intelligently filtering out answering machines, busy signals, and disconnected numbers.",
    "Maintain total operational oversight with native real-time monitoring capabilities. Listen in on active customer interactions, whisper coaching tips directly to your agents, or barge into critical calls instantly.",
    "Ensure complete regulatory compliance and quality assurance with secure, high-fidelity call recording storage automatically archived and accessible for up to 9 months."
  ],
  photo: "/img/dialer/mainReport.webp",
  pricing: '/dialer-pricing'
}
const findAndHire = {
  title: "Multiply Inbound & Outbound Contact Rates with VICIdial Experts",
  description: "Stop wasting up to 70% of your agents' shifts listening to unanswered ringtones or dead air. Our dedicated predictive dialer solutions utilize VICIdial’s advanced mathematical pacing algorithms to ensure your team only talks to live prospects. Backed by scalable infrastructure supporting a 20:1 dialing ratio, instant supervisor audio-monitoring dashboards, and a robust 9-month call recording retention policy, we handle the telemarketing technical complexities so you can focus entirely on conversions.",
  image: "/img/pages/pd.webp",
  flow: "reverse"
} 
const videoLibrary = [
  {
    id: "acc-login",
    title: "Login & Authentication",
    icon: "🔑",
    modules: [
      { name: "Agent Login", desc: "Agent authentication process, softphone registration, and WebRTC guidelines.", link: "https://www.youtube.com/watch?v=zvnSw5NqFQE&feature=youtu.be", btnClass: "bg-brand-green hover:bg-brand-green/90 text-brand-dark-blue" },
      { name: "Administrative Portal", desc: "Secure entry portal for managers, supervisors, and administrative roles.", link: "https://www.youtube.com/watch?v=6F5wC-fgufU", btnClass: "bg-brand-blue hover:bg-brand-blue/90 text-white" }
    ]
  },
  {
    id: "acc-reports",
    title: "Advanced Reports & Metrics",
    icon: "📊",
    modules: [
      { name: "Agent Time Details", desc: "In-depth breakdown of login durations, productive intervals, and custom pauses.", link: "https://youtu.be/8fan1V_NkOc", btnClass: "bg-brand-green hover:bg-brand-green/90 text-brand-dark-blue" },
      { name: "Agent Performance", desc: "Individual statistics regarding answer rates, talk time, and total conversion data.", link: "https://www.youtube.com/watch?v=XSAKU3OWIB4", btnClass: "bg-brand-blue hover:bg-brand-blue/90 text-white" },
      { name: "Team Performance", desc: "Consolidated statistics mapping overall campaign speed, SLAs, and collective outcomes.", link: "https://www.youtube.com/watch?v=jgwswJSsWt0&feature=youtu.be", btnClass: "bg-brand-green hover:bg-brand-green/90 text-brand-dark-blue" },
      { name: "Real-time Main Report", desc: "Live dashboard monitoring active calls, agent states, and remote call listening features.", link: "https://www.youtube.com/watch?v=nDQU76mUIkM", btnClass: "bg-brand-blue hover:bg-brand-blue/90 text-white" },
    ]
  },
  {
    id: "acc-manager",
    title: "Manager & Campaign Control",
    icon: "🛠️",
    modules: [
      { name: "Change amount of lines", desc: "Adjusting predictive dialing ratios dynamically to balance call volume and drops.", link: "https://www.youtube.com/watch?v=_cFEjEVcIos", btnClass: "bg-brand-green hover:bg-brand-green/90 text-brand-dark-blue" },
      { name: "Check Lead Amount in Campaign", desc: "Real-time verification of available dialable data inside active hoppers.", link: "https://youtu.be/e9M4UUdQGlI", btnClass: "bg-brand-blue hover:bg-brand-blue/90 text-white" },
      { name: "Reset Lead List", desc: "How to correctly recycle lists or leads to trigger a brand new dial cycle.", link: "https://www.youtube.com/watch?v=yVK3neacb7I", btnClass: "bg-brand-green hover:bg-brand-green/90 text-brand-dark-blue" },
      { name: "Active / Pause List", desc: "Instant toggles to execute or temporarily cease operation on database groupings.", link: "https://www.youtube.com/watch?v=3LKWipTSV_Y", btnClass: "bg-brand-blue hover:bg-brand-blue/90 text-white" },
      { name: "Upload Lead Database", desc: "CSV / Excel file optimization, mapping data layouts, and safe lead processing.", link: "https://www.youtube.com/watch?v=kdOinzDkN98", btnClass: "bg-brand-green hover:bg-brand-green/90 text-brand-dark-blue" },
      { name: "Listen up Recordings Using Stats Report", desc: "Access and evaluate agent call recordings directly through your Vicidial analytics. Streamline quality assurance by linking performance metrics with real-time audio playback.", link: "https://youtu.be/ZHUXMjL2o0U", btnClass: "bg-brand-blue hover:bg-brand-blue/90 text-white" }
    ]
  },
  {
    id: "acc-qc",
    title: "Quality Control & Compliance",
    icon: "🛡️",
    modules: [
      { name: "QC Section & Auditing", desc: "Auditing calls, recording reviews, scorecard filling, and feedback pipelines.", link: "https://www.youtube.com/watch?v=1kfxqnwtTVs", btnClass: "bg-brand-green hover:bg-brand-green/90 text-brand-dark-blue" }
    ]
  }
];
const FAQs = {
  title: "VICIdial Predictive Dialer FAQ",
  description: "Everything you need to know about line scaling ratios, remote audio monitoring, and call logging history guidelines.",
  questions: [
    {
      question: "How does the 20 lines per agent simultaneous dialing actually work?",
      answer: "Our specialized VICIdial server backend opens up to 20 lines simultaneously per active agent. The predictive algorithm routes calls at a rapid pace, drops dead air or fax tones, and bridges the call to a live agent the exact millisecond a human prospect answers."
    },
    {
      question: "Can I listen to my call center agents in real time without disruption?",
      answer: "Yes, absolutely. The web-based VICIdial Real-Time Report dashboard allows supervisors to monitor agent screens and listen to active phone streams. You can choose to Blind Monitor (listen silently), Whisper (talk only to the agent), or Barge (join the full conversation)."
    },
    {
      question: "How long are the call recordings stored and how can we access them?",
      answer: "All inbound and outbound calls are recorded in high-fidelity formats and securely archived for up to 9 months. They are indexed via date, agent ID, and phone number, allowing your QA team to pull records directly from the admin panel anytime."
    },
    {
      question: "Do you provide the telecom SIP trunks or do we bring our own?",
      answer: "We can provide fully optimized, high-CPS (Calls Per Second) wholesale VoIP termination routes tailored for predictive dialing, or our system administrators can securely connect your existing corporate SIP carriers into our cluster."
    },
    {
      question: "Can we scale our outbound capacity for high-volume seasonal campaigns?",
      answer: "Easily. Because our servers are built on highly scalable cloud server clusters, you can rapidly increase or decrease concurrent channels and agent licenses with proper structural notice."
    },
    {
      question: "How do you protect data security and adhere to calling compliance?",
      answer: "We prioritize security. Our VICIdial deployments utilize restricted IP access whitelists, encrypted web panels, dynamic firewalls, and built-in features to enforce local calling hour regulations and drop-rate compliance."
    }
  ]
}
---

<Layout title="YourServiceva | VICIdial Predictive Dialer Services">
  <Hero heroData={heroData} >
    
    {/* Tarjeta Flotante 1: Estado del Servidor / Ratio de Marcación */}
    <div class="absolute -top-14.5 md:top-0 right-44 md:-right-36 sm:right-4 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 md:flex flex-col gap-2 min-w-40 sm:min-w-47.5 animate-bounce-slow">
      <div class="flex items-center justify-between text-xs md:text-lg font-bold text-gray-400">
        <span>VICIdial Cluster</span>
        <span class="h-7 w-7 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center font-extrabold text-[10px]">20:1</span>
      </div>
      <label class="flex items-center gap-2 text-xs md:text-[14px] font-medium text-gray-400 line-through decoration-gray-300">
        <input type="checkbox" checked disabled class="rounded text-brand-green focus:ring-0 h-3.5 w-3.5" />
          Answering Machines Filtered
        </label>
      <label class="flex items-center gap-2 text-xs md:text-[14px] font-semibold text-gray-700">
        <span class="animate-pulse h-2 w-2 rounded-full bg-orange-500"></span>
        <span class="text-orange-600 font-bold">[Live Call]</span> Connected to Agent #04
      </label>
    </div>

    {/* Tarjeta Flotante 2: Consola del Supervisor - Escucha en Tiempo Real */}
    <div class="hidden absolute -top-30 left-0 md:-left-14 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 max-w-60 md:max-w-80 md:flex flex-col gap-2">
      <div class="flex items-center gap-2 border-b border-gray-100 pb-1.5">
        <div class="h-7 w-7 rounded-full bg-brand-blue text-white text-[10px] md:text-[14px] font-bold flex items-center justify-center">SV</div>
        <div class="flex flex-col">
          <span class="text-[11px] md:text-xl font-bold text-gray-800 leading-none">Real-Time Monitor</span>
          <span class="text-[9px] md:text-[14px] text-brand-green font-semibold">Supervisor Panel</span>
        </div>
      </div>
      <p class="text-[11px] md:text-[14px] font-medium text-gray-600 bg-gray-50 rounded-lg p-2 border-l-2 border-emerald-500">
        🎙️ <span class="font-bold text-gray-700">Listening Agent #12:</span> "Yes sir, the warranty covers..."
      </p>
      <p class="text-[11px] md:text-[14px] font-semibold text-white bg-brand-blue rounded-lg p-2 self-end text-right">
        [Whisper Mode Active] Remind him about the 10% discount coupon.
      </p>
    </div>

    {/* Tarjeta Flotante 3: Almacenamiento de grabaciones (9 Meses) */}
    <div class="absolute bottom-0 md:bottom-6 -right-4 bg-white/95 backdrop-blur-sm rounded-xl p-3 shadow-xl border border-gray-100 z-20 flex flex-col gap-2 min-w-37.5 sm:min-w-45">
      <div class="flex items-center gap-1.5 text-xs md:text-lg font-bold text-gray-800">
        <span class="text-brand-blue">💾</span> Storage Server <span class="text-emerald-600 font-extrabold">(9 Mo. Vault)</span>
      </div>
      <div class="flex flex-col gap-1 text-[10px] md:text-[14px] font-medium text-gray-500">
        <div class="p-1.5 bg-gray-50 rounded border-l-2 border-brand-green text-gray-700 font-semibold">Recording_2026_06_17.mp3 saved</div>
        <div class="p-1.5 bg-gray-50 rounded border-l-2 border-brand-blue">FTP Archive Sync Complete</div>
      </div>
    </div>
    
  </Hero>
  <TrustedBy />
  <GenericSection genericData={findAndHire} />
  <section class="py-20 bg-linear-to-b from-brand-dark-blue to-[#FAF8F5] border-y border-gray-100 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {/* Encabezado Principal */}
      <div class="text-center max-w-3xl mx-auto mb-16 flex flex-col gap-2">
        <span class="text-brand-green font-bold text-xs md:text-[16px] uppercase tracking-widest block">Infrastructure Powerhouse</span>
        <h2 class="text-3xl md:text-6xl font-extrabold text-white tracking-tight">
          Unfair Operational Advantages with VICIdial
        </h2>
        <p class="text-gray-300 text-sm md:text-xl leading-relaxed">
          We don't deploy standard setups. Our system builds are fine-tuned to maximize efficiency, oversight, and long-term security.
        </p>
      </div>

      {/* Distribución en dos columnas: Pilares vs Imagen */}
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        
        {/* Columna Izquierda: Los 3 Pilares Técnicos (Ocupa 7 de 12 columnas en pantallas grandes) */}
        <div class="lg:col-span-7 flex flex-col gap-6">
          
          {/* Pilar 1 */}
          <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-md border border-gray-100 flex flex-col sm:flex-row items-start gap-4 relative overflow-hidden group hover:shadow-xl transition-all duration-300">
            <div class="absolute top-0 left-0 bottom-0 w-1 bg-transparent group-hover:bg-brand-blue transition-colors duration-300"></div>
            <div class="h-12 w-12 shrink-0 rounded-xl bg-blue-50 text-brand-blue flex items-center justify-center font-bold text-xl shadow-xs">
              ⚡
            </div>
            <div class="flex flex-col gap-1">
              <h3 class="text-lg md:text-2xl font-bold text-brand-dark-blue">Up to 20 Lines Simultaneously</h3>
              <p class="text-xs md:text-lg text-gray-600 leading-relaxed font-medium">
                Keep your agents constantly talking. Our systems support up to a 20:1 dial ratio per user, instantly dropping dead lines, busy signals, and answering machines so your team handles live prospects only.
              </p>
            </div>
          </div>

          {/* Pilar 2 */}
          <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-md border border-gray-100 flex flex-col sm:flex-row items-start gap-4 relative overflow-hidden group hover:shadow-xl transition-all duration-300">
            <div class="absolute top-0 left-0 bottom-0 w-1 bg-transparent group-hover:bg-brand-blue transition-colors duration-300"></div>
            <div class="h-12 w-12 shrink-0 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center font-bold text-xl shadow-xs">
              🎧
            </div>
            <div class="flex flex-col gap-1">
              <h3 class="text-lg md:text-2xl font-bold text-brand-dark-blue">Real-Time Audio Monitoring</h3>
              <p class="text-xs md:text-lg text-gray-600 leading-relaxed font-medium">
                Listen to your call center agents live from any location. Gain absolute control using the supervisor panel to stealthily audit audio streams, whisper guidance in real time, or barge into active escalations.
              </p>
            </div>
          </div>

          {/* Pilar 3 */}
          <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-md border border-gray-100 flex flex-col sm:flex-row items-start gap-4 relative overflow-hidden group hover:shadow-xl transition-all duration-300">
            <div class="absolute top-0 left-0 bottom-0 w-1 bg-transparent group-hover:bg-brand-blue transition-colors duration-300"></div>
            <div class="h-12 w-12 shrink-0 rounded-xl bg-orange-50 text-orange-600 flex items-center justify-center font-bold text-xl shadow-xs">
              📂
            </div>
            <div class="flex flex-col gap-1">
              <h3 class="text-lg md:text-2xl font-bold text-brand-dark-blue">9-Month Secure Recording Vault</h3>
              <p class="text-xs md:text-lg text-gray-600 leading-relaxed font-medium">
                Protect your brand, settle disputes, and train your staff with confidence. Every inbound and outbound phone call is processed and securely archived for up to 9 months, ready to be audited at any moment.
              </p>
            </div>
          </div>

        </div>

        {/* Columna Derecha: Contenedor de Imagen Estilizado (Ocupa 5 de 12 columnas) */}
        <div class="lg:col-span-5 relative w-full h-full min-h-87.5 md:min-h-112.5 flex items-center justify-center group">
          {/* Efecto de fondo brillante detrás de la imagen para dar aspecto tecnológico */}
          <div class="absolute inset-0 bg-brand-blue/10 rounded-3xl filter blur-xl group-hover:bg-brand-blue/15 transition-all duration-300 scale-95"></div>
          
          {/* Envoltura de la imagen con bordes finos y sombra profunda */}
          <div class="relative w-full h-full overflow-hidden rounded-3xl border border-white/10 shadow-2xl bg-brand-dark-blue">
            <img 
              src="/img/pages/pd2.webp" 
              alt="VICIdial Predictive Dialer Infrastructure and Datacenter Servers" 
              class="w-full h-full object-cover object-center transform group-hover:scale-105 transition-transform duration-500 opacity-90 group-hover:opacity-100"
              loading="lazy"
            />
            {/* Capa de degradado sutil sobre la foto para integrarla con el fondo oscuro */}
            <div class="absolute inset-0 bg-linear-to-t from-brand-dark-blue/40 via-transparent to-transparent pointer-events-none"></div>
          </div>
        </div>

      </div>

    </div>
  </section>

  <TalentsSection />
  <HowItWorks />
  <ClientReviews />
  <section class="py-24 bg-white text-gray-900 relative overflow-hidden border-t border-gray-100">
    {/* Sutiles destellos de color de fondo muy difuminados para dar profundidad */}
    <div class="absolute top-1/4 -right-60 h-125 w-125 rounded-full bg-brand-blue/5 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 -left-60 h-125 w-125 rounded-full bg-brand-green/5 blur-[120px] pointer-events-none"></div>

    <div id="Dialer-tutos" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      {/* Encabezado Principal */}
      <div class="text-center max-w-2xl mx-auto mb-16 flex flex-col gap-3">
        <div class="flex items-center justify-center gap-2">
          <span class="inline-block h-2 w-2 rounded-full bg-brand-green shadow-[0_0_6px_rgba(164,202,57,0.6)]"></span>
          <span class="text-brand-green font-bold text-xs md:text-[16px] uppercase tracking-widest">Interactive Learning Center</span>
        </div>
        <h2 class="text-3xl md:text-6xl font-extrabold tracking-tight text-brand-dark-blue">
          How to Operate Our Dialer
        </h2>
        <p class="text-gray-600 text-xs md:text-xl leading-relaxed max-w-lg mx-auto font-medium">
          Complete transparency into our infrastructure operations. Select a category below to access our comprehensive, step-by-step technical documentation.
        </p>
      </div>

      {/* Contenedor Principal de Acordeones */}
      <div class="flex flex-col gap-5">
        {videoLibrary.map((category) => (
          <div class="bg-white rounded-2xl border border-gray-200 shadow-xs overflow-hidden transition-all duration-300 group">
            {/* Checkbox de control de estado nativo */}
            <input type="checkbox" id={category.id} class="peer hidden" />
            
            {/* Botón Disparador (Header) -> AZUL OSCURO PREMIUM */}
            <label 
              for={category.id} 
              class="flex justify-between items-center p-6 bg-brand-dark-blue hover:bg-[#0f2d52] cursor-pointer select-none transition-all duration-200 border-b border-transparent"
            >
              <div class="flex items-center gap-4">
                {/* Ícono de categoría con estilo vidriado sobre fondo oscuro */}
                <span class="h-12 w-12 rounded-xl bg-white/10 border border-white/10 text-xl flex items-center justify-center shadow-inner group-hover:scale-105 transition-all duration-300">
                  {category.icon}
                </span>
                <div class="flex flex-col text-left">
                  <span class="text-xl md:text-2xl font-bold text-white tracking-tight leading-tight">
                    {category.title}
                  </span>
                  <span class="text-[10px] md:text-lg font-bold text-brand-green uppercase tracking-wider mt-1 flex items-center gap-1.5">
                    <span class="h-1 w-1 rounded-full bg-brand-green"></span>
                    {category.modules.length} {category.modules.length === 1 ? 'Video Guide' : 'Video Guides'}
                  </span>
                </div>
              </div>
              
              {/* Indicador de flecha en alto contraste */}
              <div class="h-8 w-8 rounded-full bg-white/10 border border-white/5 flex items-center justify-center text-white transition-all duration-300 transform peer-checked:group-[]:-rotate-180 peer-checked:group-[]:bg-brand-blue peer-checked:group-[]:border-transparent">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </div>
            </label>

            {/* Contenido Desplegable -> FONDO BLANCO PURO */}
            <div class="max-h-0 overflow-hidden peer-checked:max-h-375 transition-all duration-500 ease-in-out bg-white">
              {/* Grid inteligente: Si solo hay un item, ocupa todo el ancho de forma limpia, si no, se divide en 2 columnas */}
              <div class={`p-6 grid gap-5 ${category.modules.length === 1 ? 'grid-cols-1' : 'grid-cols-1 md:grid-cols-2'}`}>
                {category.modules.map((mod) => (
                  <div class="bg-gray-50/60 border border-gray-200/80 rounded-xl p-5 flex flex-col justify-between gap-5 hover:bg-white hover:border-brand-blue/30 hover:shadow-lg hover:shadow-brand-dark-blue/2 transition-all duration-300 group/card relative overflow-hidden">
                    
                    {/* Detalles del texto con la escala de grises solicitada */}
                    <div class="flex flex-col gap-2">
                      <div class="flex items-center justify-between">
                        <span class="text-[10px] md:text-[16px] font-bold tracking-widest text-gray-400 uppercase">
                          Technical Module
                        </span>
                        {/* Badge de formato */}
                        <span class="text-[9px] md:text-[16px] font-extrabold px-2 py-0.5 rounded-md bg-white border border-gray-200 text-gray-500 shadow-2xs">
                          HD 1080p
                        </span>
                      </div>
                      <h3 class="text-sm md:text-lg font-bold text-brand-dark-blue group-hover/card:text-brand-blue transition-colors duration-200">
                        {mod.name}
                      </h3>
                      <p class="text-xs md:text-[16px] text-gray-600 font-medium leading-relaxed">
                        {mod.desc}
                      </p>
                    </div>

                    {/* Botón de reproducción adaptado para alto contraste en fondo claro */}
                    <a 
                      href={mod.link} 
                      target="_blank" 
                      rel="noopener noreferrer" 
                      class={`w-full flex items-center justify-between px-4 py-3 rounded-xl text-xs md:text-lg font-bold transition-all duration-200 border transform active:scale-98 cursor-pointer group/btn ${
                        mod.btnClass.includes('bg-brand-green') 
                          ? 'bg-brand-green/10 text-[#5b7514] border-brand-green/30 hover:bg-brand-green hover:text-brand-dark-blue hover:border-transparent hover:shadow-[0_4px_12px_rgba(164,202,57,0.25)]' 
                          : 'bg-brand-blue/5 text-brand-blue border-brand-blue/20 hover:bg-brand-blue hover:text-white hover:border-transparent hover:shadow-[0_4px_12px_rgba(0,136,204,0.25)]'
                      }`}
                    >
                      <div class="flex items-center gap-2">
                        {/* Ícono circular de Play */}
                        <div class="h-6 w-6 rounded-full bg-white border border-gray-200/80 flex items-center justify-center shadow-xs group-hover/btn:scale-110 group-hover/btn:bg-transparent group-hover/btn:border-white/20 transition-all duration-200">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 translate-x-[0.5px]">
                            <path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd" />
                          </svg>
                        </div>
                        <span>Launch Stream Tutorial</span>
                      </div>
                      
                      <span class="text-xs opacity-70 group-hover/btn:opacity-100 group-hover/btn:translate-x-0.5 transition-all">
                        →
                      </span>
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Pie Informativo */}
      <div class="mt-14 bg-gray-50 border border-gray-200 p-4 rounded-xl text-center max-w-2xl mx-auto shadow-xs">
        <p class="text-xs md:text-[16px] font-semibold text-gray-500">
          💡 <span class="text-brand-blue font-bold">Need assistance with your setup?</span> All designated managers and telemarketing admins receive custom playground credentials during technical onboarding.
        </p>
      </div>

    </div>
  </section>

  <FAQ FAQs={FAQs} />
</Layout>